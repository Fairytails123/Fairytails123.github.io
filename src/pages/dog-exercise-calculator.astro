  import '../scripts/dog-exercise-calculator/ui.js';
</script>

<!-- Page motion: standard y-only reveals + hero entrance (never hides content —
     verify-reveals gate). Mirrors the site's animation contract. -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  let mm = null;

  function initExerciseCalcMotion() {
    const root = document.querySelector('[data-page="dog-exercise-calculator"]');
    if (!root || root.dataset.gsapInit) return;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) return; // static page — everything already visible
    root.dataset.gsapInit = '1';

    mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      gsap
        .timeline({ defaults: { ease: 'power3.out' } })
        .from('[data-hero-eyebrow]', { y: 24, duration: 0.6 }, 0.1)
        .from('[data-hero-title] .hero-line', { y: 24, duration: 0.9, stagger: 0.14 }, 0.2)
        .from('[data-hero-sub]', { y: 24, duration: 0.7 }, 0.55)
        .from('[data-hero-cta] > *', { y: 18, duration: 0.55, stagger: 0.1 }, 0.72)
        .from('[data-hero-trust]', { y: 36, duration: 0.7 }, 0.85)
        .from('[data-hero-cue]', { autoAlpha: 0, duration: 0.6 }, 1.1);

      gsap.to('[data-hero-media]', {
        scale: 1.09,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: 'top top', end: 'bottom top', scrub: true },
      });
      gsap.to('[data-hero-cue]', {
        autoAlpha: 0,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: '5% top', end: '20% top', scrub: true },
      });

      gsap.utils.toArray('[data-reveal]').forEach((el) => {
        gsap.from(el, { y: 36, duration: 0.85, ease: 'power3.out', scrollTrigger: { trigger: el, start: 'top 88%', once: true } });
      });
      gsap.utils.toArray('[data-stagger]').forEach((group) => {
        gsap.from(group.children, { y: 28, duration: 0.7, ease: 'power3.out', stagger: 0.07, scrollTrigger: { trigger: group, start: 'top 88%', once: true } });
      });
    });
  }

  initExerciseCalcMotion();
  document.addEventListener('astro:page-load', initExerciseCalcMotion);
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill());
    if (mm) { mm.revert(); mm = null; }
  });
</script>
