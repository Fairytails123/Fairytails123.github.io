---
// The advice hub — legacy /blog URL, legacy <title>/description preserved.
// Cards keep each post's ORIGINAL publish date (built up 2020-2025).
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import HillDivider from '../components/HillDivider.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const categories = ['Puppies', 'Behaviour', 'Training Methods', 'Health & Care', 'Careers'].filter(
  (c) => posts.some((p) => p.data.category === c)
);
const dateFmt = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Base
  title="Dog Training Blogs and Dog Training Tips"
  description="Blogs to help understand the wider context of dog training and behaviour modification. Useful dog training tips on how to train dogs."
  path="/blog"
>
  <div data-page="blog-hub">
    <!-- ============ Hub header ============ -->
    <header class="bg-moss-900 pb-16 pt-32 sm:pb-20 sm:pt-40">
      <div class="mx-auto max-w-6xl px-4">
        <p class="eyebrow text-honey-300" data-hub-eyebrow>The advice hub</p>
        <h1 class="mt-4 max-w-2xl font-display text-4xl font-bold leading-tight text-cream-50 sm:text-5xl" data-hub-title>
          Dog training blogs &amp; <em class="squiggle not-italic">tips</em>
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-cream-200/90" data-hub-sub>
          Five years of honest advice on training, behaviour and everyday life with dogs —
          written by our trainers, one post at a time.
        </p>
      </div>
    </header>
    <HillDivider class="text-moss-900" flip />

    <!-- ============ Category filters ============ -->
    <div class="mx-auto max-w-6xl px-4 pt-8">
      <div class="flex flex-wrap gap-2.5" role="group" aria-label="Filter posts by category" data-filters>
        <button type="button" class="filter-chip is-active" data-filter="all" aria-pressed="true">
          All posts
        </button>
        {
          categories.map((c) => (
            <button type="button" class="filter-chip" data-filter={c} aria-pressed="false">
              {c}
            </button>
          ))
        }
      </div>
    </div>

    <!-- ============ Post grid ============ -->
    <section class="mx-auto max-w-6xl px-4 pb-20 pt-8">
      <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3" data-post-grid>
        {
          posts.map((post) => (
            <a
              href={`/${post.id}`}
              class="group flex flex-col overflow-hidden rounded-2xl bg-cream-50 shadow-[var(--shadow-polaroid)] transition-transform duration-300 hover:-translate-y-1"
              data-post-card
              data-category={post.data.category}
            >
              <div class="aspect-[16/10] overflow-hidden">
                <Image
                  src={post.data.heroImage}
                  alt={post.data.heroAlt}
                  widths={[480, 768]}
                  sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <p class="text-xs font-bold uppercase tracking-wide text-honey-600">
                  {post.data.category}
                  <span class="mx-1.5 text-bark-400" aria-hidden="true">•</span>
                  <time datetime={post.data.pubDate.toISOString()} class="normal-case tracking-normal text-bark-500">
                    {dateFmt.format(post.data.pubDate)}
                  </time>
                </p>
                <h2 class="mt-2.5 font-display text-xl font-bold leading-snug text-moss-800 group-hover:underline">
                  {post.data.title}
                </h2>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-bark-700">{post.data.description}</p>
                <p class="mt-4 text-sm font-bold text-moss-700">
                  Read more <span aria-hidden="true">→</span>
                </p>
              </div>
            </a>
          ))
        }
      </div>
      <p class="mt-10 hidden text-center text-bark-700" data-empty-note>
        No posts in this category yet.
      </p>
    </section>
  </div>
</Base>

<style>
  .filter-chip {
    border-radius: 9999px;
    border: 1.5px solid var(--color-moss-300);
    background: transparent;
    color: var(--color-moss-800);
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.5rem 1.1rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .filter-chip:hover {
    background: var(--color-moss-100);
  }
  .filter-chip.is-active {
    background: var(--color-moss-700);
    border-color: var(--color-moss-700);
    color: var(--color-cream-50);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function init() {
    const root = document.querySelector('[data-page="blog-hub"]') as HTMLElement | null;
    if (!root || root.dataset.gsapInit) return;
    root.dataset.gsapInit = '1';

    // --- Category filter (progressive enhancement; ?category= deep-linkable) ---
    const chips = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-filter]'));
    const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-post-card]'));
    const emptyNote = root.querySelector<HTMLElement>('[data-empty-note]');

    const apply = (filter: string) => {
      let shown = 0;
      for (const card of cards) {
        const show = filter === 'all' || card.dataset.category === filter;
        card.style.display = show ? '' : 'none';
        if (show) shown++;
      }
      for (const chip of chips) {
        const active = chip.dataset.filter === filter;
        chip.classList.toggle('is-active', active);
        chip.setAttribute('aria-pressed', String(active));
      }
      emptyNote?.classList.toggle('hidden', shown > 0);
    };

    chips.forEach((chip) => chip.addEventListener('click', () => apply(chip.dataset.filter || 'all')));

    const wanted = new URLSearchParams(location.search).get('category');
    if (wanted && chips.some((c) => c.dataset.filter === wanted)) apply(wanted);

    // --- Motion ---
    gsap.matchMedia().add('(prefers-reduced-motion: no-preference)', () => {
      gsap.from(['[data-hub-eyebrow]', '[data-hub-title]', '[data-hub-sub]', '[data-filters]'], {
        opacity: 0,
        y: 24,
        duration: 0.7,
        ease: 'power2.out',
        stagger: 0.12,
      });
      gsap.from(cards, {
        opacity: 0,
        y: 30,
        duration: 0.6,
        ease: 'power2.out',
        stagger: 0.06,
        scrollTrigger: { trigger: '[data-post-grid]', start: 'top 85%' },
      });
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill());
  });
</script>
