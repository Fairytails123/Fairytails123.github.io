<style>
  /* Class-night steps: dimmed until active (JS adds .is-active; no-JS/reduced-motion = full).
     CSS owns step opacity entirely — the entrance tween is x-only, because a gsap.from
     autoAlpha leaves inline opacity:1 behind and permanently defeats this rule (the
     silent no-op found in review 2026-07-05; the sibling pages still carry it). */
  .night-step {
    transition: opacity 0.45s ease;
  }
  [data-gsap-init] .night-step:not(.is-active) {
    opacity: 0.55;
  }

  /* Night timeline — dusk-to-moonlight trail + rising moon */
  .night-trail {
    background: linear-gradient(to bottom, var(--color-honey-300), var(--color-honey-200) 30%, var(--color-cream-100) 75%, var(--color-cream-50));
  }
  .night-moon {
    filter: drop-shadow(0 0 8px rgb(245 238 221 / 0.55));
  }

  @media (prefers-reduced-motion: reduce) {
    [data-gsap-init] .night-step:not(.is-active) {
      opacity: 1;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initVideoLoops } from '../scripts/videoLoops';

  gsap.registerPlugin(ScrollTrigger);

  function initPuppyClasses() {
    const root = document.querySelector('[data-page="puppy-classes"]') as HTMLElement | null;
    if (!root || root.dataset.gsapInit) return;
    initVideoLoops(root);

    // Hero video: lazy-start after load; never for reduced-motion or data-saver users.
    const video = root.querySelector('[data-hero-video]') as HTMLVideoElement | null;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData = (navigator as any).connection?.saveData === true;
    if (video && !reduceMotion && !saveData) {
      setTimeout(() => {
        video.load();
        video.play().catch(() => {});
      }, 350);
    }

    if (reduceMotion) return; // static page — everything already visible
    root.dataset.gsapInit = '1';

    const mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      /* --- Hero entrance --- */
      gsap
        .timeline({ defaults: { ease: 'power3.out' } })
        .from('[data-hero-eyebrow]', { y: 24, autoAlpha: 0, duration: 0.6 }, 0.1)
        .from('[data-hero-title] .hero-line', { y: 54, autoAlpha: 0, duration: 0.9, stagger: 0.14 }, 0.2)
        .from('[data-hero-sub]', { y: 24, autoAlpha: 0, duration: 0.7 }, 0.55)
        .from('[data-hero-cta] > *', { y: 18, autoAlpha: 0, duration: 0.55, stagger: 0.1 }, 0.72)
        .from('[data-hero-trust]', { y: 36, autoAlpha: 0, duration: 0.7 }, 0.85)
        .from('[data-hero-cue]', { autoAlpha: 0, duration: 0.6 }, 1.1);

      /* --- Hero parallax drift --- */
      gsap.to('[data-hero-media]', {
        scale: 1.09,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: 'top top', end: 'bottom top', scrub: true },
      });
      gsap.to('[data-hero-cue]', {
        autoAlpha: 0,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: '5% top', end: '20% top', scrub: true },
      });

      /* --- Generic reveals --- */
      gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
        gsap.from(el, {
          y: 36,
          autoAlpha: 0,
          duration: 0.85,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 86%', once: true },
        });
      });

      /* --- Staggered groups --- */
      gsap.utils.toArray<HTMLElement>('[data-stagger]').forEach((group) => {
        gsap.from(group.children, {
          y: 28,
          autoAlpha: 0,
          duration: 0.7,
          ease: 'power3.out',
          stagger: 0.07,
          scrollTrigger: { trigger: group, start: 'top 86%', once: true },
        });
      });

      /* --- Signature: a class night (the moon rises up the evening) --- */
      const list = root.querySelector('[data-night-list]') as HTMLElement | null;
      const fill = root.querySelector('[data-trail-fill]');
      const moon = root.querySelector('[data-trail-moon]') as HTMLElement | null;
      if (list && fill) {
        const trail = { trigger: list, start: 'top 62%', end: 'bottom 55%', scrub: 0.5 };
        gsap.fromTo(fill, { scaleY: 0 }, { scaleY: 1, ease: 'none', scrollTrigger: trail });
        if (moon) {
          gsap.fromTo(
            moon,
            { y: 0, rotation: 0 },
            {
              y: () => (moon.parentElement?.offsetHeight ?? 0) - 24,
              rotation: -20,
              ease: 'none',
              scrollTrigger: trail,
            }
          );
        }
      }
      gsap.utils.toArray<HTMLElement>('[data-night-step]').forEach((step) => {
        ScrollTrigger.create({
          trigger: step,
          start: 'top 68%',
          end: 'bottom 40%',
          onToggle: (self) => step.classList.toggle('is-active', self.isActive),
        });
        // x-only entrance: opacity belongs to the CSS dim/spotlight rule above —
        // tweening autoAlpha here would leave inline opacity:1 and kill the effect.
        gsap.from(step, {
          x: 40,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: { trigger: step, start: 'top 88%', once: true },
        });
      });
    });
  }

  initPuppyClasses();
  document.addEventListener('astro:page-load', initPuppyClasses);
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill());
  });
</script>
