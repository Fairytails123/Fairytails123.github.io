---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import HillDivider from '../components/HillDivider.astro';
import { business } from '../data/business';
import pricing from '../data/pricing.json';

import classNightHall from '../assets/pages/puppy-training-classes/class-night-hall.jpg';
import kamAndPup from '../assets/pages/puppy-training-classes/kam-and-pup.webp';
import puppySocialisation from '../assets/pages/puppy-training-classes/puppy-socialisation.webp';
import classesLeadWalk from '../assets/pages/puppy-training-classes/classes-lead-walk.webp';
import puppyLabSit from '../assets/pages/puppy-training-classes/puppy-lab-sit.webp';
import puppyHeadTilt from '../assets/pages/puppy-training-classes/puppy-head-tilt.webp';
import puppyTerrierGrass from '../assets/pages/puppy-training-classes/puppy-terrier-grass.webp';

const plan = pricing.offerings.find((o) => o.id === 'puppy-classes');
const puppyBoard = pricing.offerings.find((o) => o.id === 'board-train-puppy');
const puppyIntensive = pricing.offerings.find((o) => o.id === 'puppy-intensive');

const gbp = (n) => `£${Number.isInteger(n) ? n.toLocaleString('en-GB') : n.toFixed(2)}`;

// Owner-supplied curriculum (pre-build interview 2026-07-05) — connective copy only.
const weeks = [
  {
    week: 'Week 1',
    title: 'The foundations',
    body: 'Mastering basic skills — sit, down and settle — plus your first homework: good home habits that help prevent future issues such as separation anxiety and other common puppy challenges.',
  },
  {
    week: 'Week 2',
    title: 'Out into the world',
    body: 'A revision of week one, then we introduce walking outside — loose-lead walking, walking techniques, engagement and responsiveness, and more good habits for home.',
  },
  {
    week: 'Week 3',
    title: 'Recall',
    body: 'The week devoted to recall training — the skill that keeps your puppy safe and earns them their freedom.',
  },
  {
    week: 'Week 4',
    title: 'The real world',
    body: 'Everything comes together with a practical session outside, in a real-world environment.',
  },
];

// DRAFT class-night rundown (owner to fine-tune on the preview — interview 2026-07-05).
const classNight = [
  { time: '6:00pm', title: 'Arrive & settle', body: 'Mats down, a sniff and a hello — pups settle beside their parents with a few calm treats while everyone arrives.' },
  { time: '6:10pm', title: 'Warm-up', body: 'Name games and focus exercises — easy wins that switch every puppy into learning mode.' },
  { time: '6:25pm', title: 'The week’s skill', body: 'The main lesson of the night, broken into puppy-sized steps you practise together.' },
  { time: '6:40pm', title: 'Practice & socialising', body: 'Short, supervised mixing between pups — confidence-building and controlled, never a free-for-all.' },
  { time: '6:55pm', title: 'Q&A + homework', body: 'Your questions answered and the week’s homework set, so the progress carries on at home.' },
  { time: '7:00pm', title: 'Home time', body: 'Tired brains, waggy tails — see you next Thursday.' },
];

// Verbatim "what you will learn" list from the harvest copy.
const learnList = [
  'Diets and nutrition',
  'Building strong foundations',
  'More advanced commands',
  'Long lead training with distractions',
  'Day school sessions',
  'Training with hand signals',
  'Explore and master dog law',
  'Learn body language and voice tones to help your pup focus',
];

// Verbatim benefit cards from the harvest copy.
const benefits = [
  { title: 'Enjoyable classes', body: 'Puppies have short attention spans, so it’s important to make training a positive experience.' },
  { title: 'Building confidence', body: 'Exposure to a variety of stimuli during classes will help them learn to adapt and feel comfortable in different situations.' },
  { title: 'Professional trainers', body: 'Your puppy will experience structured training and socialisation opportunities under the guidance of professional trainers.' },
  { title: 'A strong foundation', body: 'Establishing a strong foundation of obedience early on will contribute to a well-mannered and well-adjusted adult dog.' },
];

// Entry requirements (interview 2026-07-05: same vaccine set as day school —
// the course includes three day-school intro sessions).
const entryRules = [
  'Classes are perfect for all pups under 6 months old.',
  'Vaccinations up to date — DHP, Leptospirosis and Kennel Cough (the same set our day school asks for, since your course includes three day-school intro sessions).',
  'The day school’s admission rules apply during your three intro sessions — including that females in season can’t attend the day school while they’re in season. We’ll walk you through the rest when you book.',
];

// DRAFT kit list (owner to correct on the preview — interview 2026-07-05).
const kitList = [
  'Plenty of high-value treats, chopped small',
  'A flat collar or fitted harness, plus a normal lead (no extendable leads)',
  'A mat or blanket from home for settle work',
  'Your puppy’s vaccination card (first class)',
  'A favourite toy',
  'Water and a bowl for your pup',
];

// DRAFT FAQs — conservative, enquiry-first answers (flagged for owner review).
const faqs = [
  {
    q: 'When should we start?',
    a: 'As early as possible — puppies are like sponges, absorbing information and learning quickly during their early weeks. Our classes are perfect for all pups under 6 months old.',
  },
  {
    q: 'My puppy hasn’t finished their vaccinations yet — can we still book?',
    a: 'Yes — book your place, and we’ll time your start around your pup’s jabs. Classes and the day-school intro sessions need DHP, Leptospirosis and Kennel Cough vaccinations up to date, so if your puppy is mid-course, get in touch and we’ll plan the right start date together.',
  },
  {
    q: 'My puppy is nervous (or a little bitey) — is a group class right for them?',
    a: 'That’s exactly what early classes are for. Groups are kept small, there are at least two trainers in the room, and mixing between pups is short and carefully supervised. If we honestly think a group setting isn’t the right fit for your puppy, we’ll say so and point you to a better route.',
  },
  {
    q: 'What if we miss a session?',
    a: 'Life happens — let us know as soon as you can and we’ll do our best to help you catch up. The weekly homework keeps things moving at home, and we always begin the next class with a revision of what came before.',
  },
  {
    q: 'Can the whole family come along?',
    a: 'We’d love the whole household on board — that’s how the training sticks. Bring a partner or older children if you like, with one main handler per pup on the night. Just let us know who’s coming when you book.',
  },
];
---

<Base
  title="Puppy Training Classes in Hastings & St Leonards | The Fairy Tails"
  description="Small group puppy training evening classes based in Hastings for your pup and you! The experienced trainers will help you give your puppy the best start."
  path="/puppy-training-classes"
>
  <div data-page="puppy-classes">
    <!-- ============ HERO ============ -->
    <section class="relative isolate flex min-h-[92svh] items-end overflow-hidden bg-pine-950" data-hero>
      <div class="absolute inset-0 -z-10 overflow-hidden">
        <!-- Hero loop cut from the owner's reserved puppy-class clip (real class
             night in the hall); poster doubles as the reduced-motion/fallback state. -->
        <video
          class="h-full w-full object-cover"
          poster="/media/puppy-classes-poster.jpg"
          muted
          loop
          playsinline
          preload="none"
          data-hero-video
          data-hero-media
          aria-hidden="true"
        >
          <source src="/media/puppy-classes-hero.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-t from-pine-950/95 via-pine-950/45 to-pine-950/25"></div>
      </div>

      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-36 sm:pb-28">
        <p class="eyebrow text-honey-300" data-hero-eyebrow>Puppy Training Classes · Concordia Hall, St Leonards</p>
        <h1 class="mt-4 max-w-3xl font-display text-[2.6rem] font-bold leading-[1.05] text-cream-50 sm:text-6xl" data-hero-title>
          <span class="hero-line block">Give your puppy</span>
          <span class="hero-line block">the <em class="squiggle not-italic">best start</em></span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-cream-100/90" data-hero-sub>
          Small group evening classes for local pups and their parents — four Thursday evenings,
          three intro sessions at our dog day school, and a month of learning together.
        </p>
        <div class="mt-9 flex flex-wrap gap-4" data-hero-cta>
          <a href="#enquire" class="btn btn-honey">
            Send an enquiry <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <a href={plan.acuityUrl} class="btn btn-ghost-light">Reserve your place — {gbp(plan.price)}</a>
        </div>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-cream-100/70" data-hero-cue aria-hidden="true">
        <svg width="22" height="30" viewBox="0 0 22 30" fill="none" class="animate-bounce">
          <rect x="1" y="1" width="20" height="28" rx="10" stroke="currentColor" stroke-width="2"></rect>
          <circle cx="11" cy="10" r="3" fill="currentColor"></circle>
        </svg>
      </div>
    </section>

    <!-- Trust strip — overlaps the hero -->
    <div class="relative z-10 mx-auto -mt-12 max-w-5xl px-4" data-hero-trust>
      <ul class="grain grid gap-4 rounded-2xl bg-cream-50 px-7 py-6 text-sm font-bold text-bark-700 shadow-[var(--shadow-polaroid)] sm:grid-cols-3 sm:gap-2">
        <li class="paw-bullet flex items-center text-moss-700">Perfect for all pups under 6 months</li>
        <li class="paw-bullet flex items-center text-moss-700">At least two trainers at every class</li>
        <li class="paw-bullet flex items-center text-moss-700">Three day-school intro sessions included</li>
      </ul>
    </div>

    <!-- ============ WELCOME ============ -->
    <section class="mx-auto max-w-6xl px-4 py-20 sm:py-28" data-section="welcome">
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <p class="eyebrow text-honey-600" data-reveal>Small group evening classes</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
            For your puppy — <em class="squiggle not-italic">and for you</em>
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-bark-700" data-reveal>
            The Fairy Tails are pleased to provide group puppy training classes for local pups and
            their parents. Classes are held at Concordia Hall, St. Leonards on Thursday evenings
            at 6pm.
          </p>
          <p class="mt-4 leading-relaxed text-bark-700" data-reveal>
            Puppy training is a crucial aspect of raising a well-behaved and happy dog. Our group
            training classes include teaching your puppy basic commands, socialising them with
            people and other dogs, and establishing a positive relationship between you and your
            furry companion.
          </p>
        </div>
        <figure class="polaroid mx-auto w-full max-w-sm" style="transform: rotate(-2deg);" data-reveal>
          <Image
            src={classNightHall}
            alt="A puppy settling on its mat at a Fairy Tails class in Concordia Hall"
            class="aspect-[4/5] w-full rounded-[2px] object-cover"
            widths={[480, 960]}
            sizes="(min-width: 1024px) 24rem, 90vw"
          />
          <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">
            Class night at Concordia Hall
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- ============ WHY GROUP CLASSES ============ -->
    <section class="bg-cream-100" data-section="why">
      <HillDivider class="bg-cream-50 text-cream-100" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-600" data-reveal>Why choose group classes</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
          Puppies are <em class="squiggle not-italic">sponges</em> — let’s make it count
        </h2>

        <div class="mt-12 grid items-start gap-6 lg:grid-cols-2">
          <div class="space-y-6" data-stagger>
            <article class="grain rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)]">
              <h3 class="font-display text-xl font-bold text-moss-700">Start training early</h3>
              <p class="mt-3 leading-relaxed text-bark-700">
                The ideal time to start training your puppy is as early as possible. Puppies are
                like sponges, absorbing information and learning quickly during their early weeks.
                Our classes are perfect for all pups under 6 months old.
              </p>
            </article>
            <article class="grain rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)]">
              <div class="flex items-start gap-5">
                <div class="min-w-0">
                  <h3 class="font-display text-xl font-bold text-moss-700">Two dog trainers</h3>
                  <p class="mt-3 leading-relaxed text-bark-700">
                    There will be at least two dog trainers present at our group classes, using and
                    teaching positive reinforcement techniques to help your pup learn happily.
                  </p>
                </div>
                <Image
                  src={kamAndPup}
                  alt="A Fairy Tails trainer cuddling a puppy"
                  class="hidden aspect-square w-24 shrink-0 rounded-xl object-cover sm:block"
                  widths={[96, 192]}
                  sizes="6rem"
                />
              </div>
            </article>
            <article class="grain rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)]">
              <h3 class="font-display text-xl font-bold text-moss-700">Socialisation</h3>
              <p class="mt-3 leading-relaxed text-bark-700">
                It’s important to expose your puppy to various environments, people, and other dogs
                to promote socialisation. This helps prevent fear and aggression issues as your
                puppy grows. Group classes and exposure to the dog school is an ideal opportunity
                for your pup!
              </p>
            </article>
          </div>

          <div class="grain rounded-2xl bg-moss-800 p-8 text-cream-50 shadow-[var(--shadow-lift)]" data-reveal>
            <h3 class="font-display text-2xl font-bold text-cream-50">What you will learn</h3>
            <p class="mt-3 leading-relaxed text-cream-100">
              Training will include basic commands such as sit, stay and come, plus we can help
              with the following:
            </p>
            <ul class="mt-5 space-y-2.5" data-stagger>
              {learnList.map((item) => <li class="paw-bullet flex items-start text-cream-100">{item}</li>)}
            </ul>
            <figure class="mt-7 overflow-hidden rounded-xl">
              <Image
                src={classesLeadWalk}
                alt="A puppy on a loose lead looking up at its handler"
                class="aspect-[16/9] w-full object-cover"
                widths={[480, 960]}
                sizes="(min-width: 1024px) 32rem, 90vw"
              />
            </figure>
          </div>
        </div>

        <p class="mt-8 rounded-2xl bg-cream-50 p-6 leading-relaxed text-bark-700 shadow-[var(--shadow-lift)]" data-reveal>
          <strong class="text-moss-800">What’s included:</strong> the course includes four sessions
          spread over one month plus three intro sessions to
          <a href="/dog-day-school" class="font-bold text-moss-700 underline decoration-honey-400 decoration-2 underline-offset-2">The Fairy Tails dog day school</a>.
        </p>
      </div>
    </section>

    <!-- ============ THE FOUR WEEKS ============ -->
    <section data-section="weeks">
      <HillDivider class="bg-cream-100 text-cream-50" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-600" data-reveal>The course, week by week</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
          One month, four evenings — <em class="squiggle not-italic">a plan that builds</em>
        </h2>

        <div class="mt-12 grid items-start gap-10 lg:grid-cols-[1fr_0.5fr]">
          <ol class="space-y-6 overflow-x-clip" data-week-list data-stagger>
            {
              weeks.map((w, i) => (
                <li class="grain relative rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)]">
                  <div class="flex items-baseline gap-4">
                    <p class="font-display text-5xl font-bold leading-none text-honey-400/80">{i + 1}</p>
                    <div>
                      <p class="eyebrow text-honey-600">{w.week}</p>
                      <h3 class="mt-1 font-display text-xl font-bold text-moss-800">{w.title}</h3>
                    </div>
                  </div>
                  <p class="mt-4 leading-relaxed text-bark-700">{w.body}</p>
                </li>
              ))
            }
          </ol>

          <figure class="polaroid mx-auto w-full max-w-[15rem] sm:max-w-[17rem] lg:sticky lg:top-28" style="transform: rotate(2deg);" data-reveal>
            <video
              class="aspect-[9/16] w-full rounded-[2px] object-cover"
              muted
              loop
              playsinline
              preload="none"
              poster="/media/puppy-walk-poster.jpg"
              data-src="/media/puppy-walk-loop.mp4"
              aria-label="A golden retriever puppy trotting happily on a loose lead through the park"
            ></video>
            <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">
              Week 2, out in the world
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ============ A CLASS NIGHT — signature scroll story ============ -->
    <section class="relative overflow-hidden bg-pine-950 text-cream-100" data-section="night">
      <HillDivider class="relative z-10 bg-cream-50 text-pine-950" flip />
      <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-2/3" aria-hidden="true" style="background: radial-gradient(60% 50% at 78% 0%, rgba(245,238,221,0.13), transparent 70%), radial-gradient(70% 55% at 20% 100%, rgba(236,194,124,0.10), transparent 72%);"></div>
      <!-- a few faint stars -->
      <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-1/2 opacity-60" aria-hidden="true" style="background-image: radial-gradient(1.5px 1.5px at 12% 18%, rgba(245,238,221,0.8), transparent), radial-gradient(1px 1px at 32% 34%, rgba(245,238,221,0.6), transparent), radial-gradient(1.5px 1.5px at 55% 12%, rgba(245,238,221,0.7), transparent), radial-gradient(1px 1px at 72% 28%, rgba(245,238,221,0.55), transparent), radial-gradient(1.5px 1.5px at 88% 16%, rgba(245,238,221,0.75), transparent), radial-gradient(1px 1px at 45% 42%, rgba(245,238,221,0.5), transparent);"></div>

      <div class="relative z-10 mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-400" data-reveal>A class night</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-cream-50 sm:text-4xl" data-reveal>
          One hour on a Thursday, <em class="squiggle not-italic">well spent</em>
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-cream-200" data-reveal>
          Every class night has the same friendly rhythm — arrive, warm up, learn, practise, and
          head home with homework. Here’s how the hour unfolds.
        </p>

        <!-- The night: a moonlit trail fills + the moon rises as you scroll -->
        <div class="relative mt-14 overflow-x-clip" data-night-list>
          {/* Mobile track sits at 15px so the -15px moon span stays inside the
              overflow-x-clip wrapper (7px clipped the moon's left edge). */}
          <div class="absolute bottom-4 left-[15px] top-2 w-0.5 sm:left-[110px]" aria-hidden="true">
            <div class="absolute inset-0 rounded bg-pine-800"></div>
            <div class="night-trail absolute inset-0 origin-top rounded" data-trail-fill></div>
            <span class="night-moon absolute -left-[15px] top-0 block h-8 w-8" data-trail-moon>
              <svg viewBox="0 0 32 32" fill="none" class="h-full w-full">
                <path
                  d="M22 4.5a11.5 11.5 0 1 0 5.4 15.9A9.5 9.5 0 0 1 22 4.5z"
                  fill="var(--color-cream-100)"
                ></path>
                <circle cx="10.5" cy="12" r="1.2" fill="var(--color-cream-300)"></circle>
                <circle cx="14" cy="18.5" r="1.6" fill="var(--color-cream-300)"></circle>
              </svg>
            </span>
          </div>

          <ol class="space-y-10 sm:space-y-12">
            {
              classNight.map((step) => (
                <li class="night-step relative grid gap-2 pl-9 sm:grid-cols-[84px_1fr] sm:gap-12 sm:pl-0" data-night-step>
                  <p class="font-display text-base font-bold uppercase tracking-wide text-honey-400 sm:text-right">
                    {step.time}
                  </p>
                  <div class="sm:pl-14">
                    <h3 class="font-display text-2xl font-bold text-cream-50">{step.title}</h3>
                    <p class="mt-2 max-w-2xl leading-relaxed text-cream-200">{step.body}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>

        <p class="mt-14 max-w-3xl rounded-2xl bg-pine-900 p-6 leading-relaxed text-cream-100" data-reveal>
          <strong class="text-honey-300">Where and when:</strong> Concordia Hall, St. Leonards —
          Thursday evenings at 6pm. Courses run on a rolling basis: book your place and we’ll
          contact you to slot you into the next available course.
        </p>
      </div>
    </section>

    <!-- ============ HOW YOUR PUP BENEFITS ============ -->
    <section data-section="benefits">
      <HillDivider class="bg-pine-950 text-cream-50" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-600" data-reveal>Beyond the commands</p>
        <h2 class="mt-3 font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
          How will your pup <em class="squiggle not-italic">benefit?</em>
        </h2>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {
            benefits.map((b) => (
              <article class="grain rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)] transition-transform duration-300 hover:-translate-y-1.5">
                <h3 class="font-display text-lg font-bold text-moss-800">{b.title}</h3>
                <p class="mt-2.5 text-sm leading-relaxed text-bark-700">{b.body}</p>
              </article>
            ))
          }
        </div>

        <div class="mt-16 grid items-center gap-12 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="relative mx-auto h-[24rem] w-full max-w-md" data-reveal>
            <figure class="polaroid absolute left-0 top-2 w-3/5" style="transform: rotate(-4deg);">
              <Image src={puppyLabSit} alt="A young puppy sitting and looking up attentively" class="aspect-[4/5] w-full rounded-[2px] object-cover" widths={[360, 720]} sizes="16rem" />
            </figure>
            <figure class="polaroid absolute bottom-0 right-0 w-3/5" style="transform: rotate(3.5deg);">
              <Image src={puppySocialisation} alt="Two puppies sitting together at class" class="aspect-square w-full rounded-[2px] object-cover" widths={[360, 720]} sizes="16rem" />
            </figure>
          </div>
          <div>
            <h3 class="font-display text-2xl font-bold text-moss-800" data-reveal>Building a bond with your puppy</h3>
            <p class="mt-4 leading-relaxed text-bark-700" data-reveal>
              Puppy training classes can significantly strengthen the bond between you and your
              puppy. Training establishes a form of communication between you and your puppy.
              Through consistent commands and cues, your puppy learns to understand your
              expectations, and you learn to interpret their responses. This mutual understanding
              fosters a sense of connection.
            </p>
            <h3 class="mt-8 font-display text-2xl font-bold text-moss-800" data-reveal>Understanding your pup</h3>
            <p class="mt-4 leading-relaxed text-bark-700" data-reveal>
              Through training classes, with the help of our trainer you can gain insights into
              your puppy’s personality, preferences, and learning style. Similarly, your puppy
              becomes attuned to your cues and expectations. This mutual understanding deepens the
              connection between you and your furry friend.
            </p>
            <h3 class="mt-8 font-display text-2xl font-bold text-moss-800" data-reveal>A positive experience</h3>
            <p class="mt-4 leading-relaxed text-bark-700" data-reveal>
              The use of positive reinforcement, such as treats, praise, affection and play
              reinforces the idea that good behaviour leads to positive outcomes. This positive
              feedback loop strengthens the bond as your puppy learns that following your guidance
              brings rewards.
            </p>
