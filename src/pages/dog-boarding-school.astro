<style>
  /* Regime steps: dimmed until active (JS adds .is-active; no-JS/reduced-motion = full) */
  .regime-step {
    transition: opacity 0.45s ease;
  }
  [data-gsap-init] .regime-step:not(.is-active) {
    opacity: 0.55;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-gsap-init] .regime-step:not(.is-active) {
      opacity: 1;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initVideoLoops } from '../scripts/videoLoops';

  gsap.registerPlugin(ScrollTrigger);

  // Reverted on astro:before-swap — matchMedia contexts otherwise leak across
  // ClientRouter navigations (membership-review fix, applied site-wide at polish).
  let mm = null;

  function initBoardTrain() {
    const root = document.querySelector('[data-page="board-train"]') as HTMLElement | null;
    if (!root || root.dataset.gsapInit) return;
    initVideoLoops(root);

    // The click-to-play town film paints an opaque black box (controls + inline src,
    // no poster) over its lazy underlay image — borrow the underlay's rendition as
    // the poster the moment it loads (same URL, cache hit).
    const film = root.querySelector('video[controls]') as HTMLVideoElement | null;
    const filmUnderlay = film?.parentElement?.querySelector('img') as HTMLImageElement | null;
    if (film && filmUnderlay) {
      const setFilmPoster = () => {
        if (filmUnderlay.currentSrc) film.poster = filmUnderlay.currentSrc;
      };
      if (filmUnderlay.complete) setFilmPoster();
      else filmUnderlay.addEventListener('load', setFilmPoster, { once: true });
    }

    // Hero video: lazy-start after load; never for reduced-motion or data-saver users.
    const video = root.querySelector('[data-hero-video]') as HTMLVideoElement | null;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData = (navigator as any).connection?.saveData === true;
    if (video && !reduceMotion && !saveData) {
      // Start the film only after the poster underlay has painted: if the video's
      // first frame wins that race, Chrome records the 1.8 MB mp4 as the LCP
      // resource and throttled-mobile LCP collapses (measured 5.5 s before this).
      // The film must not paint a frame before the user's first interaction: Chrome
      // records a video's first frame as an LCP candidate that REPLACES the poster
      // image's, so an early frame makes the 1.8 MB mp4 the page's LCP resource — in
      // Lighthouse (measured 5.5 s) AND in real-user CrUX. LCP observation stops at
      // the first input/scroll, so a film that starts on interaction never counts.
      const underlay = root.querySelector('[data-hero] img') as HTMLImageElement | null;
      let filmStarted = false;
      const startFilm = () => {
        if (filmStarted || !video.isConnected) return;
        filmStarted = true;
        setTimeout(() => {
          // The loading video paints black without a poster — reuse the underlay's
          // already-fetched rendition (same URL, cache hit).
          if (underlay?.currentSrc) video.poster = underlay.currentSrc;
          video.load();
          video.play().catch(() => {});
        }, 350);
      };
      let filmArmed = false;
      const armFilm = () => {
        if (filmArmed) return;
        filmArmed = true;
        ['pointerdown', 'pointermove', 'touchstart', 'scroll', 'keydown'].forEach((t) =>
          window.addEventListener(t, startFilm, { once: true, passive: true })
        );
        setTimeout(startFilm, 15000); // motionless visitor — start the film anyway
      };
      if (!underlay || underlay.complete) armFilm();
      else {
        underlay.addEventListener('load', armFilm, { once: true });
        setTimeout(armFilm, 2500); // image stalled/erred — the film must still arm
      }
    }

    if (reduceMotion) return; // static page — everything already visible
    root.dataset.gsapInit = '1';

    mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      /* --- Hero entrance --- */
      gsap
        .timeline({ defaults: { ease: 'power3.out' } })
        .from('[data-hero-eyebrow]', { y: 24, duration: 0.6 }, 0.1)
        .from('[data-hero-title] .hero-line', { y: 24, duration: 0.9, stagger: 0.14 }, 0.2)
        .from('[data-hero-sub]', { y: 24, duration: 0.7 }, 0.55)
        .from('[data-hero-cta] > *', { y: 18, duration: 0.55, stagger: 0.1 }, 0.72)
        .from('[data-hero-trust]', { y: 36, duration: 0.7 }, 0.85)
        .from('[data-hero-cue]', { autoAlpha: 0, duration: 0.6 }, 1.1);

      /* --- Hero parallax drift --- */
      gsap.to('[data-hero-media]', {
        scale: 1.09,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: 'top top', end: 'bottom top', scrub: true },
      });
      gsap.to('[data-hero-cue]', {
        autoAlpha: 0,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: '5% top', end: '20% top', scrub: true },
      });

      /* --- Generic reveals --- */
      gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
        gsap.from(el, {
          y: 36,
          duration: 0.85,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 86%', once: true },
        });
      });

      /* --- Staggered groups --- */
      gsap.utils.toArray<HTMLElement>('[data-stagger]').forEach((group) => {
        gsap.from(group.children, {
          y: 28,
          duration: 0.7,
          ease: 'power3.out',
          stagger: 0.07,
          scrollTrigger: { trigger: group, start: 'top 86%', once: true },
        });
      });

      /* --- Signature: the week-by-week walk --- */
      const list = root.querySelector('[data-regime-list]') as HTMLElement | null;
      const fill = root.querySelector('[data-trail-fill]');
      const paw = root.querySelector('[data-trail-paw]') as HTMLElement | null;
      if (list && fill) {
        const trail = {
          trigger: list,
          start: 'top 62%',
          end: 'bottom 55%',
          scrub: 0.5,
        };
        gsap.fromTo(fill, { scaleY: 0 }, { scaleY: 1, ease: 'none', scrollTrigger: trail });
        if (paw) {
          gsap.fromTo(
            paw,
            { y: 0, rotation: -8 },
            {
              y: () => (paw.parentElement?.offsetHeight ?? 0) - 12,
              rotation: 8,
              ease: 'none',
              scrollTrigger: trail,
            }
          );
        }
      }
      gsap.utils.toArray<HTMLElement>('[data-regime-step]').forEach((step) => {
        ScrollTrigger.create({
          trigger: step,
          start: 'top 68%',
          end: 'bottom 40%',
          onToggle: (self) => step.classList.toggle('is-active', self.isActive),
        });
        gsap.from(step, {
          // x-only: the step CSS owns opacity (dim rule) — autoAlpha here left
          // inline opacity:1 behind and silently defeated the dim (2026-07-05 lesson).
          x: 40,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: { trigger: step, start: 'top 88%', once: true },
        });
      });
    });

    /* --- Drag-to-scroll polaroid rail (mouse; touch uses native scroll) --- */
    const track = root.querySelector('[data-drag-track]') as HTMLElement | null;
    if (track) {
      let down = false;
      let moved = false;
      let startX = 0;
      let startScroll = 0;
      track.addEventListener('pointerdown', (e) => {
        if (e.pointerType !== 'mouse') return;
        down = true;
        moved = false;
        startX = e.clientX;
        startScroll = track.scrollLeft;
        track.classList.add('dragging');
        track.setPointerCapture(e.pointerId);
      });
      track.addEventListener('pointermove', (e) => {
        if (!down) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        track.scrollLeft = startScroll - dx;
      });
      const release = () => {
        down = false;
        track.classList.remove('dragging');
      };
      track.addEventListener('pointerup', release);
      track.addEventListener('pointercancel', release);
      track.addEventListener(
        'click',
        (e) => {
          if (moved) {
            e.preventDefault();
            e.stopPropagation();
          }
        },
        true
      );
    }
  }

  initBoardTrain();
  document.addEventListener('astro:page-load', initBoardTrain);
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill());
    if (mm) {
      mm.revert();
      mm = null;
    }
  });
</script>
