---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import CouncilRating from '../components/CouncilRating.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import HillDivider from '../components/HillDivider.astro';
import { business } from '../data/business';
import pricing from '../data/pricing.json';

import puppyTraining from '../assets/pages/dog-boarding-school/Puppy-Training-1920w.webp';
import puppySquare from '../assets/pages/dog-boarding-school/Puppy-Training-square-2880w.webp';
import busLab from '../assets/pages/dog-boarding-school/Black-Lab-on-the-bus-square-2-2880w.webp';
import shepherd from '../assets/pages/dog-boarding-school/German-Shepherd-Training-1920w.webp';
import dogWalk from '../assets/pages/dog-boarding-school/Dog-walk-with-Kam-2880w.webp';
import collie from '../assets/pages/dog-boarding-school/Collie-Training-2880w.webp';
import goldenPuppy from '../assets/pages/dog-boarding-school/Golden-Puppy-cut-out-1920w.webp';
import cycleIndoor from '../assets/pages/dog-boarding-school/Training-Cycle-Graphic-2-1920w.webp';
import cycleOutdoor from '../assets/pages/dog-boarding-school/Training-Cycle-Graphic-Outside-Areas-1920w.webp';
import trainingReport from '../assets/pages/dog-boarding-school/Training-Report-2880w.webp';

const boardTrain = pricing.offerings
  .filter((o) => o.category === 'board-train')
  .sort((a, b) => a.order - b.order);

const issues = [
  'Pulling on the lead',
  'Toilet training',
  'Social skills',
  'Reactivity',
  'Barking at the door',
  'General or trigger based anxiety',
  'Excessive play biting',
  'Growling or biting',
  'Crate training',
  'Prey drive',
  'Hyperactivity',
  'Other forms of issues',
];

const kitList = [
  'Puppy crate/dog crate – if your dog is trained to sleep in it or if required for training',
  'Puppy toys/dog toys (which can be destroyed by the dog) – chew toys',
  'Yaks Milk Chew',
  "Pizzle sticks or other chews – such as cows' ear, pigs ear, beef tendon, chicken necks, etc.",
  'Puppy food/dog food – with instructions',
  'Puppy/dog bedding',
  'Puppy/dog harness – Perfect Fit or any snug, comfortable Y-shaped harness with a front loop plus a handle on top (Ancol, Truedog, Rabbitgoo, Hurtta). Hurtta is our favourite',
  'Walking lead – Halti lead with double clips (a normal lead with clips at either end)',
  '3-inch carabiner pack',
  '20 ft training lead',
  'Vet bed',
  'High cartilage-based chew',
  'Prebiotic: Purina Fortiflora',
  'Multivitamin tablets (Purina only)',
  'Nutri Calm tablets or a prescription from your vet if your dog is nervous',
  'Adaptil plug-in',
  'Dog snood – for nervous dogs',
  'Jumper – for cold weather',
];

const regime = [
  {
    label: 'Week 1',
    title: 'Settling in',
    body: 'Your dog moves in, meets the household and our daycare crew, and builds a routine. Integration comes first — a relaxed dog is a dog who can learn.',
  },
  {
    label: 'Week 2',
    title: 'Back to basics',
    body: 'Essential commands and calm behaviours, taught in the quiet around the barn — space and tranquillity, no distractions.',
  },
  {
    label: 'Weeks 3–4',
    title: 'Building up — and parent training begins',
    body: 'Skills get stronger and real-life situations are layered in. From week 4, parent training starts: Friday sessions where you learn to speak your dog’s new language (pick-up between 11am and 2pm).',
  },
  {
    label: 'Mid-course',
    title: 'A week off at home',
    body: 'Dogs must have a week off — rest is part of learning. Your dog comes home, practises living with you, and you see the progress first-hand. Where logistics allow, dogs also benefit from weekends at home.',
  },
  {
    label: 'Weeks 5–7',
    title: 'Specialised training',
    body: 'Out into the real world: on-lead at local dog parks, along the seafront promenade and through busy high streets — wherever your dog’s plan needs us to be.',
  },
  {
    label: 'Weeks 8–9',
    title: 'Individual training & handover',
    body: 'The last pieces are tightened up one-to-one, and we transition your dog back to you — with mid-course and end-of-course parent sessions so you’re confident carrying it on.',
  },
];

const bookingSteps = [
  {
    title: 'Contact us',
    body: 'Send us the list of issues you’re facing — or the single biggest one you’d like us to focus on.',
  },
  {
    title: 'Prioritise',
    body: 'We put your list into priority order and send it back so we can agree what matters most, together.',
  },
  {
    title: 'Contract',
    body: 'A service contract sets out our obligations to you, and yours to us. Your dog’s issues are trained holistically and at the same time — training can’t work in isolation — while keeping the main issue in focus.',
  },
  {
    title: 'Agreement',
    body: 'You return the signed contract with the fees and registration form, and training starts on our mutually agreed date.',
  },
];

const clientCards = [
  { img: puppySquare, caption: 'Residential Puppy Training', rotate: -2.5 },
  { img: busLab, caption: 'In town training', rotate: 1.8 },
  { img: shepherd, caption: 'All breeds welcome', rotate: -1.2 },
  { img: dogWalk, caption: "It's not all hard work!", rotate: 2.4 },
  { img: collie, caption: 'Focus, even mid-adventure', rotate: -1.8 },
  { img: goldenPuppy, caption: 'Start them young', rotate: 1.4 },
];

const gbp = (n: number) => `£${n.toLocaleString('en-GB')}`;
---

<Base
  title="Dog Boarding School — Board & Train | The Fairy Tails K9 Centre"
  description="Residential dog training for dogs and puppies in the heart of the Sussex countryside. Let us do the hard work and you enjoy the benefits of our training."
  path="/dog-boarding-school"
>
  <div data-page="board-train">
    <!-- ============ HERO ============ -->
    <section class="relative isolate flex min-h-[92svh] items-end overflow-hidden bg-pine-950" data-hero>
      <div class="absolute inset-0 -z-10 overflow-hidden">
        <!-- Live-site film, compressed; poster doubles as the reduced-motion/fallback state.
             TODO(owner): swap in your chosen hero clip when ready (page spec open item). -->
        <video
          class="h-full w-full object-cover"
          poster="/media/board-train-poster.jpg"
          muted
          loop
          playsinline
          preload="none"
          data-hero-video
          data-hero-media
          aria-hidden="true"
        >
          <source src="/media/board-train-hero.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-t from-pine-950/95 via-pine-950/45 to-pine-950/30"></div>
      </div>

      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-36 sm:pb-28">
        <p class="eyebrow text-honey-300" data-hero-eyebrow>
          Residential dog training · Hastings, East Sussex
        </p>
        <h1 class="mt-4 max-w-3xl font-display text-[2.6rem] font-bold leading-[1.05] text-cream-50 sm:text-6xl" data-hero-title>
          <span class="hero-line block">Your dog boards and</span>
          <span class="hero-line block"><em class="squiggle not-italic">trains with us</em></span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-cream-100/90" data-hero-sub>
          We do the hard work in the heart of the Sussex countryside — and you get back a dog you
          can take anywhere, and the calm, joyful walks you've been dreaming of.
        </p>
        <div class="mt-9 flex flex-wrap gap-4" data-hero-cta>
          <a href="#enquire" class="btn btn-honey">
            Send an enquiry <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <a href={business.acuity.freeConsult} class="btn btn-ghost-light"> Book a free phone consult </a>
        </div>
      </div>

      <!-- Scroll cue -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-cream-100/70" data-hero-cue aria-hidden="true">
        <svg width="22" height="30" viewBox="0 0 22 30" fill="none" class="animate-bounce">
          <rect x="1" y="1" width="20" height="28" rx="10" stroke="currentColor" stroke-width="2"></rect>
          <circle cx="11" cy="10" r="3" fill="currentColor"></circle>
        </svg>
      </div>
    </section>

    <!-- Trust strip — overlaps the hero -->
    <div class="relative z-10 mx-auto -mt-12 max-w-5xl px-4" data-hero-trust>
      <ul class="grain grid gap-4 rounded-2xl bg-cream-50 px-7 py-6 text-sm font-bold text-bark-700 shadow-[var(--shadow-polaroid)] sm:grid-cols-2 sm:gap-2 lg:grid-cols-4">
        <li class="paw-bullet flex items-center text-moss-700">5-star council-licensed premises</li>
        <li class="paw-bullet flex items-center text-moss-700">Visit your dog anytime</li>
        <li class="paw-bullet flex items-center text-moss-700">Daily reports + body-cam video of every session</li>
        <li class="paw-bullet flex items-center text-moss-700">No kennels — your dog lives with us</li>
      </ul>
    </div>

    <!-- ============ THE PROBLEM ============ -->
    <section class="mx-auto max-w-6xl px-4 py-20 sm:py-28" data-section="problem">
      <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr]">
        <div>
          <h2 class="font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
            Does this sound like <em class="squiggle not-italic">your dog?</em>
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-bark-700" data-reveal>
            You love them to bits — but the pulling, the barking, the lunging at other dogs… it's
            exhausting. You're not a bad owner, and your dog isn't a bad dog. These are the issues
            we deal with day in, day out:
          </p>
          <ul class="mt-7 flex flex-wrap gap-2.5" data-stagger>
            {
              issues.map((issue) => (
                <li class="rounded-full border-2 border-moss-200 bg-cream-100 px-4 py-2 text-sm font-bold text-moss-800 transition-colors duration-200 hover:border-honey-400 hover:bg-honey-200/40">
                  {issue}
                </li>
              ))
            }
          </ul>
          <p class="mt-7 text-bark-700" data-reveal>
            If your dog's problem isn't listed here,
            <a href="#enquire" class="font-bold text-moss-700 underline decoration-honey-400 decoration-2 underline-offset-4">please ask us</a>
            — we may well be able to help.
          </p>
        </div>
        <figure class="polaroid mx-auto w-full max-w-sm" style="transform: rotate(2deg);" data-reveal>
          <Image
            src={puppyTraining}
            alt="Puppy in training at The Fairy Tails"
            class="aspect-[4/5] w-full rounded-[2px] object-cover"
            widths={[480, 960]}
            sizes="(min-width: 1024px) 24rem, 90vw"
          />
          <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">
            School in session
          </figcaption>
        </figure>
      </div>

      <!-- Regulated-care trust panel — boarding is a council-licensed activity -->
      <div class="grain mt-16 rounded-3xl bg-pine-900 p-8 sm:p-10" data-reveal>
        <div class="grid items-center gap-8 lg:grid-cols-[auto_1fr] lg:gap-10">
          <CouncilRating
            size="lg"
            licence
            align="center"
            class="lg:border-r lg:border-cream-100/15 lg:pr-10"
          />
          <div>
            <h3 class="font-display text-2xl font-bold text-cream-50 sm:text-3xl">
              Care within a <em class="squiggle not-italic">regulated framework</em>
            </h3>
            <p class="mt-4 leading-relaxed text-cream-200">
              Board &amp; Train means your dog boards with us — and boarding dogs is a licensed
              activity, not something anyone can simply set up and offer. We are a premises
              licensed and inspected by {business.licence.authority}, operating under the Animal
              Welfare (Licensing of Activities Involving Animals) Regulations 2018 and government
              welfare guidance. Council inspectors visit, assess and award every licensed premises
              a star rating — and we hold the highest one there is:
              <strong class="text-cream-50">{business.licence.rating} stars</strong>.
            </p>
            <p class="mt-3 text-sm leading-relaxed text-cream-200/80">
              That means the standards behind your dog's stay — housing, supervision, records,
              enrichment and welfare — are independently checked, not just promised.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ THE PROGRAMME ============ -->
    <section class="bg-cream-100" data-section="programme">
      <HillDivider class="bg-cream-50 text-cream-100" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-600" data-reveal>The programme</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
          A boarding school for dogs and puppies
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-bark-700" data-reveal>
          At The Fairy Tails we offer intensive dog training in the form of a training boot camp:
          your dog boards and trains with us for assured results. We take the stress out of
          training by doing it for you — giving your dog the greatest possible start, then handing
          you a simple training schedule so you can spend more time enjoying your dog, comfortable
          taking them wherever you go.
        </p>
        <div class="mt-12 grid gap-6 md:grid-cols-3" data-stagger>
          <article class="grain rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)] transition-transform duration-300 hover:-translate-y-1.5">
            <h3 class="font-display text-2xl font-bold text-moss-700">A positive environment</h3>
            <p class="mt-4 leading-relaxed text-bark-700">
              Your dog lives with us in our house and at our daycare while undergoing daily
              training — a totally customised routine that can greatly impact behaviour in as
              little as three to four weeks. It's hard to choose who to trust with your cherished
              family dog: our knowledgeable trainers use positive techniques in a loving, safe and
              secure environment.
            </p>
          </article>
          <article class="grain rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)] transition-transform duration-300 hover:-translate-y-1.5">
            <h3 class="font-display text-2xl font-bold text-moss-700">We do the hard work</h3>
            <p class="mt-4 leading-relaxed text-bark-700">
              The key to dog training is consistency, regularity, and a controlled, supervised
              environment — difficult for busy families. If your schedule doesn't allow for
              training, if past attempts or other trainers haven't worked, or if you simply don't
              want to do it yourself, this is your programme.
            </p>
          </article>
          <article class="grain rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)] transition-transform duration-300 hover:-translate-y-1.5">
            <h3 class="font-display text-2xl font-bold text-moss-700">Your dog stays with us</h3>
            <p class="mt-4 leading-relaxed text-bark-700">
              There are no kennels at our house. Your dog is evaluated, given time to adjust, and
              lives here with us — becoming our pet for a period agreed between you and the
              trainer, based on your dog's issues and your wishes. Our clients come from all over
              the UK and trust us with their fur children.
            </p>
          </article>
        </div>
        <p class="mt-9 max-w-3xl text-bark-700" data-reveal>
          All breeds are welcome, and we train pups from as young as twelve weeks — as long as
          they've had their second set of vaccinations. <strong>There is never a wrong time!</strong>
        </p>
      </div>
    </section>

    <!-- ============ PROOF ============ -->
    <section class="overflow-hidden py-20 sm:py-28" data-section="proof">
      <div class="mx-auto max-w-6xl px-4">
        <p class="eyebrow text-honey-600" data-reveal>Proof, not promises</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
          We'll never sell you a <em class="squiggle not-italic">guaranteed fix</em>
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-bark-700" data-reveal>
          No honest trainer can. What we can show you is how we actually work, every single day.
        </p>

        <div class="mt-12 grid gap-6 lg:grid-cols-2" data-stagger>
          <article class="grain rounded-2xl border-2 border-cream-200 bg-cream-100 p-8">
            <p class="eyebrow text-honey-600">Archie's story</p>
            <h3 class="mt-3 font-display text-2xl font-bold text-moss-800">
              Why we'll never promise you a quick fix
            </h3>
            <p class="mt-4 leading-relaxed text-bark-700">
              Archie, a young Labradoodle with severe separation anxiety and big feelings around
              other dogs, responded beautifully to positive reinforcement training. His story is
              also an honest lesson in why a family's follow-through matters as much as ours — and
              why "guaranteed results" from any trainer should be a red flag. Read it before
              choosing a trainer. Including us.
            </p>
            <a
              href="/archiestory"
              class="mt-5 inline-flex items-center gap-1.5 font-bold text-moss-700 underline decoration-honey-400 decoration-2 underline-offset-4"
            >
              Read Archie's full story <span aria-hidden="true">→</span>
            </a>
          </article>

          <!-- Real town-training film (owner's edit, 2026-07-04). Click-to-play with
               sound; preload=none so the 27 MB file only loads on demand. -->
          <article class="grain overflow-hidden rounded-2xl border-2 border-cream-200 bg-cream-100">
            <video
              class="aspect-video w-full bg-pine-950"
              controls
              preload="none"
              poster="/media/bt-town-training-poster.jpg"
              src="/media/bt-town-training.mp4"
            ></video>
            <div class="p-6">
              <h3 class="font-display text-2xl font-bold text-moss-800">Watch us work</h3>
              <p class="mt-2 leading-relaxed text-bark-700">
                A real training session, start to finish — through the streets, seafront and cafés
                of Hastings. Busy pavements, traffic, other dogs: this is exactly the real world
                your dog learns to be calm in. Press play — this is the proof.
              </p>
            </div>
          </article>
        </div>
      </div>

      <!-- Draggable polaroid rail (full-bleed) -->
      <div class="mt-14" data-reveal>
        <h3 class="mx-auto max-w-6xl px-4 font-display text-2xl font-bold text-moss-800">
          Just some of our lovely doggy clients
        </h3>
        <p class="mx-auto mt-1 max-w-6xl px-4 text-sm font-bold text-bark-400">
          Drag to explore <span aria-hidden="true">⟷</span>
        </p>
        <div
          class="drag-track mt-6 flex snap-x snap-mandatory gap-7 overflow-x-auto px-[max(1rem,calc((100vw-72rem)/2+1rem))] pb-6 pt-2"
          data-drag-track
        >
          {
            clientCards.map(({ img, caption, rotate }) => (
              <figure
                class="polaroid w-64 shrink-0 snap-start sm:w-72"
                style={`transform: rotate(${rotate}deg);`}
              >
                <Image
                  src={img}
                  alt={caption}
                  class="aspect-square w-full rounded-[2px] object-cover"
                  widths={[480, 960]}
                  sizes="18rem"
                  draggable={false}
                />
                <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">
                  {caption}
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>

      <!-- TODO(owner): testimonials + before/after photo pairs — awaiting picks (page spec open items). -->
      <div class="mx-auto mt-10 grid max-w-6xl gap-6 px-4 md:grid-cols-2" data-stagger>
        <article class="rounded-2xl border-2 border-dashed border-moss-300 bg-cream-50 p-7 text-center">
          <h3 class="font-display text-xl font-bold text-moss-700">What our families say</h3>
          <p class="mt-2 leading-relaxed text-bark-700">Real words from board-and-train families are coming here.</p>
        </article>
        <article class="rounded-2xl border-2 border-dashed border-moss-300 bg-cream-50 p-7 text-center">
          <h3 class="font-display text-xl font-bold text-moss-700">Before &amp; after</h3>
          <p class="mt-2 leading-relaxed text-bark-700">
            Side-by-side transformations — reactive on lead to calm in town — are coming here.
          </p>
        </article>
      </div>
    </section>

    <!-- ============ TRAINING REGIME — signature scroll story ============ -->
    <section class="bg-pine-950 text-cream-100" data-section="regime">
      <HillDivider class="bg-cream-50 text-pine-950" flip />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-400" data-reveal>The journey</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-cream-50 sm:text-4xl" data-reveal>
          What the weeks <em class="squiggle not-italic">look like</em>
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-cream-200" data-reveal>
          Every dog's plan is tailored with you before they arrive — but here's the typical shape
          of a full course for an adult dog.
        </p>

        <!-- The walk: a trail line fills + a paw walks down it as you scroll -->
        <div class="relative mt-14 overflow-x-clip" data-regime-list>
          <div class="absolute bottom-4 left-[7px] top-2 w-0.5 sm:left-[166px]" aria-hidden="true">
            <div class="absolute inset-0 rounded bg-moss-800"></div>
            <div class="absolute inset-0 origin-top rounded bg-honey-400" data-trail-fill></div>
            <span
              class="paw-bullet absolute -left-[9px] top-0 block h-5 w-5 text-honey-300"
              data-trail-paw></span>
          </div>

          <ol class="space-y-12 sm:space-y-14">
            {
              regime.map((step, i) => (
                <li
                  class="regime-step relative grid gap-2 pl-9 sm:grid-cols-[140px_1fr] sm:gap-12 sm:pl-0"
                  data-regime-step
                  data-step={i + 1}
                >
                  <p class="font-display text-lg font-bold uppercase tracking-wide text-honey-400 sm:text-right">
                    {step.label}
                  </p>
                  <div class="sm:pl-14">
                    <h3 class="font-display text-2xl font-bold text-cream-50">{step.title}</h3>
                    <p class="mt-2.5 max-w-2xl leading-relaxed text-cream-200">{step.body}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>

        <p class="mt-14 max-w-3xl rounded-2xl bg-pine-900 p-6 leading-relaxed text-cream-100" data-reveal>
          <strong class="text-honey-300">Puppies are different:</strong> pups aged 12–16 weeks run
          a shorter 4-week course (with a transition week after) — at that age they're a blank
          canvas, and four weeks sets a great foundation.
        </p>

        <div class="mt-12 grid gap-6 md:grid-cols-2" data-stagger>
          <figure>
            <Image
              src={cycleIndoor}
              alt="The Fairy Tails boarding dog training cycle — in-facility environments"
              class="rounded-2xl bg-cream-50"
              widths={[640, 1280]}
              sizes="(min-width: 768px) 50vw, 100vw"
            />
            <figcaption class="mt-3 text-sm font-bold text-cream-200">The boarding training cycle</figcaption>
          </figure>
          <figure>
            <Image
              src={cycleOutdoor}
              alt="The Fairy Tails boarding dog training cycle — outside areas and real-world environments"
              class="rounded-2xl bg-cream-50"
              widths={[640, 1280]}
              sizes="(min-width: 768px) 50vw, 100vw"
            />
            <figcaption class="mt-3 text-sm font-bold text-cream-200">Outside-areas training cycle</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ============ OWNER INVOLVEMENT ============ -->
    <section class="overflow-hidden" data-section="involvement">
      <HillDivider class="bg-pine-950 text-cream-50" />
      <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 pb-20 pt-12 sm:pb-28 lg:grid-cols-2">
        <figure class="polaroid mx-auto w-full max-w-[17rem] sm:max-w-xs" style="transform: rotate(-2deg);" data-reveal>
          <video
            class="aspect-[9/16] w-full rounded-[2px] object-cover"
            muted
            loop
            playsinline
            preload="none"
            poster="/media/bt-owner-loop-poster.jpg"
