---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import HillDivider from '../components/HillDivider.astro';
import { business } from '../data/business';
import pricing from '../data/pricing.json';

// Hero backdrop (reuse now, swap later — page spec §Media)
import heroPhoto from '../assets/pages/gallery/gallery-15.webp';
// Proof "daily life" rail — reused gallery photos (consent-confirmed 2026-07-01; first names only)
import railA from '../assets/pages/gallery/scene-1-betty.webp';
import railB from '../assets/pages/gallery/train-5-april.webp';
import railC from '../assets/pages/gallery/client-2-rolo.jpg';
import railD from '../assets/pages/gallery/scene-27-henry.webp';
import railE from '../assets/pages/gallery/train-99-rollo.webp';
import railF from '../assets/pages/gallery/client-30-betty.jpg';
import railG from '../assets/pages/gallery/scene-19-enzo.webp';
import railH from '../assets/pages/gallery/train-84-bay.webp';
import railI from '../assets/pages/gallery/client-53-teddy.jpg';
// Whole-dog-club / lifestyle imagery (reused)
import clubBarn from '../assets/pages/dog-day-school/the-barn-1920w.webp';
import clubWalk from '../assets/pages/dog-day-school/happy-walk-2880w.webp';
import clubFriends from '../assets/pages/dog-day-school/doggy-friends-2880w.webp';
import reassurePhoto from '../assets/pages/gallery/scene-11-rollo.webp';
// About/team — Kam on a countryside walk (reused; swap for a real founder/team shot)
import teamKam from '../assets/pages/dog-boarding-school/Dog-walk-with-Kam-2880w.webp';

const gbp = (n: number) => `£${n.toLocaleString('en-GB')}`;
const bySort = (a: any, b: any) => a.order - b.order;

// --- Two tracks, rendered from pricing.json (single source of truth) ---
const flagshipBoard = pricing.offerings.find((o) => o.id === 'board-train-adult')!;
const flagshipIntensive = pricing.offerings.find((o) => o.id === 'intensive-dog-training')!;
const trainingGrid = pricing.offerings
  .filter(
    (o) =>
      (o.category === 'board-train' || o.category === 'training') &&
      o.id !== 'board-train-adult' &&
      o.id !== 'intensive-dog-training'
  )
  .sort(bySort);
const dayFull = pricing.offerings.find((o) => o.id === 'day-full')!;
const dayHalf = pricing.offerings.find((o) => o.id === 'day-half-am')!;
const memberships = pricing.offerings.filter((o) => o.category === 'membership').sort(bySort);
const socialWalks = pricing.offerings.find((o) => o.id === 'social-walks')!;

// Where each supporting service card links (built pages, or enquiry-first where the page isn't live yet)
const detailHref: Record<string, string> = {
  'board-train-puppy': '/dog-boarding-school',
  'board-train-holiday': '/dog-boarding-school',
  'puppy-intensive': '/intensive-dog-training',
  'puppy-classes': '/puppy-training-classes',
  'one-to-one': '#enquire',
  'social-walks': '#enquire',
  'free-consult': business.acuity.freeConsult,
};

// The pains that bring people to us (drives the reassurance band + issue chips)
const pains = [
  'Pulling on the lead',
  'Lunging at other dogs',
  'Barking at everything',
  "Won't come back",
  "Can't settle",
  'Anxious & overwhelmed',
  'Nervous of the world',
  'Reactive on walks',
];

// The whole-dog club — one place for a dog's whole life
const journey = [
  { title: 'Train', body: 'Kind, force-free training that actually changes behaviour.' },
  { title: 'Day school', body: 'Enrichment-led days of play, friends and structure.' },
  { title: 'Board', body: 'A home-from-home in the countryside when you’re away.' },
  { title: 'Groom', body: 'Looking as good as they feel, at our sister salon.' },
  { title: 'Belong', body: 'A club that keeps a hand on your shoulder for life.' },
];

// Proof rail — reused gallery photos, first-name captions (consent-confirmed)
const rail = [
  { img: railA, name: 'Betty', caption: 'Out on the seafront', rotate: -2.4 },
  { img: railB, name: 'April', caption: 'Focus work in town', rotate: 1.8 },
  { img: railC, name: 'Rolo', caption: 'A day at day school', rotate: -1.4 },
  { img: railD, name: 'Henry', caption: 'Exploring the Old Town', rotate: 2.2 },
  { img: railE, name: 'Rollo', caption: 'Lead skills on the high street', rotate: -1.9 },
  { img: railF, name: 'Betty', caption: 'Making new friends', rotate: 1.4 },
  { img: railG, name: 'Enzo', caption: 'Countryside adventures', rotate: -2.1 },
  { img: railH, name: 'Bay', caption: 'Settled and calm', rotate: 1.6 },
  { img: railI, name: 'Teddy', caption: 'Playtime at the barn', rotate: -1.3 },
];

// Life in the club
const clubLife = [
  {
    title: 'Dog grooming',
    body: 'From a full groom to a quick tidy — kept looking their best at our sister salon.',
    href: business.groomingSite,
    external: true,
    cta: 'Visit the grooming site',
  },
  {
    title: 'Boarding at The Barn',
    body: 'A five-star home-from-home in the Sussex countryside while you’re away.',
    href: '/dog-boarding-school',
    external: false,
    cta: 'About boarding',
  },
  {
    title: 'Social walks',
    body: `${gbp(socialWalks.price)} per walk, small groups of five — for dogs who’ve trained with us.`,
    href: '#enquire',
    external: false,
    cta: 'Ask about walks',
  },
  {
    title: 'Doggy events',
    body: 'Summer barbecues and a Christmas party for our club dogs and their families.',
    href: '#enquire',
    external: false,
    cta: 'Join the club',
  },
];

// JSON-LD — the site's primary structured data lives on the homepage
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: business.name,
  url: business.domain,
  telephone: business.phones.main.tel.replace('tel:', ''),
  email: business.emails.info,
  address: {
    '@type': 'PostalAddress',
    streetAddress: `${business.address.line1}, ${business.address.line2}`,
    addressLocality: business.address.town,
    postalCode: business.address.postcode,
    addressCountry: business.address.countryCode,
  },
  geo: { '@type': 'GeoCoordinates', latitude: business.geo.lat, longitude: business.geo.lng },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: business.hours.jsonLd.days,
      opens: business.hours.jsonLd.opens,
      closes: business.hours.jsonLd.closes,
    },
  ],
  sameAs: [business.socials.facebook, business.socials.instagram],
  areaServed: 'Hastings & 1066 Country, East Sussex',
  priceRange: '££',
};
---

<Base
  title="Dog Training, Day School & Board & Train in Hastings | The Fairy Tails K9 Centre"
  description="Kind, force-free dog training, day school and board & train near Hastings — turning anxious, reactive dogs into calmer, happier companions. Book a free consult."
  path="/"
>
  <div data-page="home">
    <!-- ============ HERO — the 3D transformation moment (signature) ============ -->
    <section class="relative isolate flex min-h-[92svh] items-end overflow-hidden bg-pine-950" data-hero>
      <div class="absolute inset-0 -z-10 overflow-hidden">
        <!-- Static photo: the LCP + the reduced-motion / no-WebGL fallback (page spec §Hero). -->
        <Image
          src={heroPhoto}
          alt=""
          class="h-full w-full object-cover opacity-45"
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          data-hero-media
        />
        <!-- WebGL "settling storm" — lazy-loaded after paint, skipped for reduced-motion / data-saver. -->
        <canvas class="absolute inset-0 h-full w-full" data-hero-canvas aria-hidden="true"></canvas>
        <div class="absolute inset-0 bg-gradient-to-t from-pine-950/95 via-pine-950/60 to-pine-950/40"></div>
      </div>

      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-36 sm:pb-28">
        <p class="eyebrow text-honey-300" data-hero-eyebrow>
          Dog training · day school · board &amp; train — Hastings
        </p>
        <h1 class="mt-4 max-w-3xl font-display text-[2.6rem] font-bold leading-[1.05] text-cream-50 sm:text-6xl" data-hero-title>
          <span class="hero-line block">The dog you love</span>
          <span class="hero-line block">is still <em class="squiggle not-italic">in there.</em></span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-cream-100/90" data-hero-sub>
          Kind, real-world training and day school that turns anxious, reactive or overwhelmed dogs
          into calmer, happier companions — in the heart of the Sussex countryside.
        </p>
        <div class="mt-9 flex flex-wrap gap-4" data-hero-cta>
          <a href="#enquire" class="btn btn-honey">
            Start your enquiry <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <a href={business.phones.main.whatsapp} class="btn btn-ghost-light">Or talk to us</a>
        </div>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-cream-100/70" data-hero-cue aria-hidden="true">
        <svg width="22" height="30" viewBox="0 0 22 30" fill="none" class="animate-bounce">
          <rect x="1" y="1" width="20" height="28" rx="10" stroke="currentColor" stroke-width="2"></rect>
          <circle cx="11" cy="10" r="3" fill="currentColor"></circle>
        </svg>
      </div>
    </section>

    <!-- Trust strip — overlaps the hero -->
    <div class="relative z-10 mx-auto -mt-12 max-w-5xl px-4" data-hero-trust>
      <ul class="grain grid gap-4 rounded-2xl bg-cream-50 px-7 py-6 text-sm font-bold text-bark-700 shadow-[var(--shadow-polaroid)] sm:grid-cols-3 sm:gap-2">
        <li class="paw-bullet flex items-center text-moss-700">Force-free &amp; qualified</li>
        <li class="paw-bullet flex items-center text-moss-700">Real-world countryside training</li>
        <li class="paw-bullet flex items-center text-moss-700">Daily reports home</li>
      </ul>
    </div>

    <!-- ============ REASSURANCE — "we've helped dogs just like yours" ============ -->
    <section class="mx-auto max-w-6xl px-4 py-20 sm:py-28" data-section="reassurance">
      <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr]">
        <div>
          <p class="eyebrow text-honey-600" data-reveal>You're not alone in this</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
            We've helped dogs <em class="squiggle not-italic">just like yours</em>
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-bark-700" data-reveal>
            The pulling, the barking, the lunging, the dog who just won't settle — it's exhausting,
            and it can feel lonely. But these are the everyday things we work with, dog after dog:
          </p>
          <ul class="mt-7 flex flex-wrap gap-2.5" data-stagger>
            {
              pains.map((p) => (
                <li class="rounded-full border-2 border-moss-200 bg-cream-100 px-4 py-2 text-sm font-bold text-moss-800 transition-colors duration-200 hover:border-honey-400 hover:bg-honey-200/40">
                  {p}
                </li>
              ))
            }
          </ul>
          <p class="mt-7 text-lg leading-relaxed text-bark-700" data-reveal>
            You're not failing them, and they're not a lost cause — they just haven't had the right
            help yet. <strong>That's exactly what we do.</strong>
          </p>
          <div class="mt-8 flex flex-wrap gap-4" data-reveal>
            <a href="#Trainingplans" class="btn btn-moss">See how we help <span class="btn-arrow" aria-hidden="true">→</span></a>
            <a href="#enquire" class="btn btn-ghost-light !border-moss-300 !text-moss-700 hover:!bg-moss-100">Start your enquiry</a>
          </div>
        </div>
        <figure class="polaroid mx-auto w-full max-w-sm" style="transform: rotate(2deg);" data-reveal>
          <Image
            src={reassurePhoto}
            alt="A once-nervous dog relaxed and confident out in the countryside"
            class="aspect-[4/5] w-full rounded-[2px] object-cover"
            widths={[480, 960]}
            sizes="(min-width: 1024px) 24rem, 90vw"
          />
          <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">
            Calm, confident, out in the world
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- ============ THE WHOLE-DOG CLUB — the difference ============ -->
    <section class="bg-cream-100" data-section="club-difference">
      <HillDivider class="bg-cream-50 text-cream-100" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-600" data-reveal>Why Fairy Tails</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
          One place for the <em class="squiggle not-italic">whole</em> of their life
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-bark-700" data-reveal>
          Most trainers hand you a course and wave goodbye. We're an exclusive premier club for the
          most beloved dogs in 1066 country — training, day school, boarding, grooming and lifelong
          support, all under one roof. One team who knows your dog inside out, for as long as you
          have them.
        </p>

        <ol class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-5" data-stagger>
          {
            journey.map((stop, i) => (
              <li class="grain relative rounded-2xl bg-cream-50 p-6 shadow-[var(--shadow-lift)] transition-transform duration-300 hover:-translate-y-1.5">
                <span class="font-display text-4xl font-bold leading-none text-honey-400/80">{i + 1}</span>
                <h3 class="mt-3 font-display text-xl font-bold text-moss-800">{stop.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-bark-700">{stop.body}</p>
              </li>
            ))
          }
        </ol>

        <div class="mt-10 flex flex-wrap items-center gap-3" data-reveal>
          <span class="paw-bullet inline-flex items-center rounded-full border-2 border-moss-200 bg-cream-50 px-4 py-2 text-sm font-bold text-moss-700">
            Committed to pain-free dog care
          </span>
          <span class="paw-bullet inline-flex items-center rounded-full border-2 border-moss-200 bg-cream-50 px-4 py-2 text-sm font-bold text-moss-700">
            Committed to improving industry standards
          </span>
        </div>
      </div>
    </section>

    <!-- ============ TRACK 1 — Training that transforms ============ -->
    <section id="Trainingplans" class="bg-pine-950 text-cream-100 scroll-mt-24" data-section="track-training">
      <HillDivider class="bg-cream-100 text-pine-950" flip />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-400" data-reveal>Track 1 · for dogs who are struggling</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-cream-50 sm:text-4xl" data-reveal>
          Training that <em class="squiggle not-italic">transforms</em>
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-cream-200" data-reveal>
          When the everyday things have become too much, this is where we do the hard work for you —
          then hand you back a dog you can take anywhere.
        </p>

        <!-- Two flagship programmes -->
        <div class="mt-12 grid gap-6 lg:grid-cols-2" data-stagger>
          {
            [
              { plan: flagshipBoard, href: '/dog-boarding-school', tag: 'Board with us', blurb: 'Your dog lives and trains with us in the countryside — the deepest, fastest change for the toughest cases.' },
              { plan: flagshipIntensive, href: '/intensive-dog-training', tag: 'Home every night', blurb: 'The same intensive programme, but your dog comes home each evening — full day school by day.' },
            ].map(({ plan, href, tag, blurb }) => (
              <article class="grain flex flex-col rounded-2xl bg-pine-900 p-8 ring-1 ring-cream-100/10">
                <p class="eyebrow text-honey-400">{tag}</p>
                <h3 class="mt-2 font-display text-2xl font-bold text-cream-50">{plan.name}</h3>
                <p class="mt-4">
                  <span class="font-display text-4xl font-bold text-honey-300">{gbp(plan.price)}</span>
                  <span class="font-bold text-cream-200"> {plan.unit}</span>
                </p>
                {plan.largeDogSurcharge && (
                  <p class="mt-1.5 text-sm font-bold text-honey-300/90">+{gbp(plan.largeDogSurcharge)} for large dogs</p>
                )}
                <p class="mt-4 leading-relaxed text-cream-200">{blurb}</p>
                <ul class="mt-5 flex-1 space-y-2.5 text-[0.95rem] text-cream-100">
                  {plan.features.map((f) => (
                    <li class="paw-bullet flex items-start text-honey-200/90">
                      <span class="text-cream-100">{f}</span>
                    </li>
                  ))}
                </ul>
                <div class="mt-7 flex flex-wrap gap-3">
                  <a href="#enquire" class="btn btn-honey">Enquire</a>
                  <a href={href} class="btn btn-ghost-light">Explore this programme</a>
                </div>
              </article>
            ))
          }
        </div>

        <!-- The rest of the training range -->
        <h3 class="mt-16 font-display text-2xl font-bold text-cream-50" data-reveal>The full training range</h3>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          {
            trainingGrid.map((plan) => (
              <a
                href={detailHref[plan.id] ?? '#enquire'}
                class="group flex h-full flex-col rounded-2xl bg-pine-900/70 p-6 ring-1 ring-cream-100/10 transition-colors duration-300 hover:ring-honey-400/60"
              >
                <h4 class="font-display text-lg font-bold text-cream-50">{plan.name}</h4>
                <p class="mt-2">
                  <span class="font-display text-2xl font-bold text-honey-300">
                    {plan.price === 0 ? 'Free' : gbp(plan.price)}
                  </span>
                  {plan.price !== 0 && <span class="text-sm font-bold text-cream-200"> {plan.unit}</span>}
                </p>
                {plan.eligibility && <p class="mt-2 text-sm text-cream-200/80">{plan.eligibility}</p>}
                <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-bold text-honey-300">
                  Learn more
                  <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
                </span>
              </a>
            ))
          }
        </div>
        <p class="mt-9 max-w-3xl text-cream-200" data-reveal>
          Not sure which fits? <a href="#enquire" class="font-bold text-honey-300 underline decoration-honey-600 underline-offset-4">Tell us about your dog</a>
          and we'll point you to the right one — or
          <a href={business.acuity.freeConsult} class="font-bold text-honey-300 underline decoration-honey-600 underline-offset-4">book a free phone consult</a>.
        </p>
      </div>
    </section>

    <!-- ============ TRACK 2 — Day-to-day care & the club ============ -->
    <section class="bg-cream-100" data-section="track-care">
      <HillDivider class="bg-pine-950 text-cream-100" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-600" data-reveal>Track 2 · everyday care</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
          Everyday care, <em class="squiggle not-italic">done beautifully</em>
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-bark-700" data-reveal>
          Busy week? Our day school keeps your dog happy, active and learning — and membership makes
          it effortless.
        </p>

        <!-- Day school -->
        <div class="mt-12 grid items-center gap-8 lg:grid-cols-2" data-reveal>
          <figure class="polaroid mx-auto w-full max-w-md" style="transform: rotate(-1.6deg);">
            <Image
              src={clubFriends}
              alt="Dogs playing together at day school"
              class="aspect-[4/3] w-full rounded-[2px] object-cover"
              widths={[640, 1024]}
              sizes="(min-width: 1024px) 28rem, 90vw"
            />
            <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">
              A busy, happy day at school
            </figcaption>
          </figure>
          <div class="grain rounded-2xl bg-cream-50 p-8 shadow-[var(--shadow-lift)]">
            <h3 class="font-display text-2xl font-bold text-moss-800">Dog Day School</h3>
            <p class="mt-3 leading-relaxed text-bark-700">
              Enrichment-led days of play, friends, structure and light training — with a school bus
              that brings them there and back.
            </p>
            <div class="mt-5 flex flex-wrap gap-x-8 gap-y-3">
              <p>
                <span class="font-display text-3xl font-bold text-moss-700">{gbp(dayFull.price)}</span>
                <span class="font-bold text-bark-500"> full day</span>
              </p>
              <p>
                <span class="font-display text-3xl font-bold text-moss-700">{gbp(dayHalf.price)}</span>
                <span class="font-bold text-bark-500"> half day</span>
              </p>
            </div>
            <p class="mt-2 text-sm font-bold text-honey-700">
              From {gbp(dayFull.weeklyDiscountPrice)}/day on a regular weekly booking
            </p>
            <a href="/dog-day-school" class="btn btn-moss mt-6">
              Day school &amp; cost estimator <span class="btn-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <!-- Membership -->
        <div id="MembershipPlans" class="mt-16 scroll-mt-24">
          <h3 class="font-display text-2xl font-bold text-moss-800" data-reveal>Membership &amp; the club</h3>
          <p class="mt-3 max-w-3xl leading-relaxed text-bark-700" data-reveal>
            For registered school dogs — bundle your days and save, with grooming perks and priority
            spaces.
          </p>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
            {
              memberships.map((plan) => (
                <article class="flex h-full flex-col rounded-2xl border-2 border-cream-200 bg-cream-50 p-6 transition-colors duration-300 hover:border-honey-400">
                  <h4 class="font-display text-lg font-bold text-moss-800">{plan.name}</h4>
                  <p class="mt-3">
                    <span class="font-display text-2xl font-bold text-moss-700">{gbp(plan.price)}</span>
                    <span class="text-sm font-bold text-bark-500"> {plan.unit}</span>
                  </p>
                  <ul class="mt-4 flex-1 space-y-1.5 text-sm text-bark-700">
                    {plan.features.slice(0, 3).map((f) => (
                      <li class="paw-bullet flex items-start">{f}</li>
                    ))}
                  </ul>
                </article>
              ))
            }
          </div>
          <a href="/membership-plans" class="btn btn-moss mt-8" data-reveal>
            Compare membership plans <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============ BREED MATCHER — inline interactive value section ============ -->
    <section class="bg-pine-900 text-cream-100" data-section="breed-matcher">
      <HillDivider class="bg-cream-100 text-pine-900" flip />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <div class="mx-auto max-w-3xl text-center">
          <p class="eyebrow text-honey-400" data-reveal>Free tool</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-cream-50 sm:text-4xl" data-reveal>
            Is your breed really a <em class="squiggle not-italic">fit?</em>
          </h2>
