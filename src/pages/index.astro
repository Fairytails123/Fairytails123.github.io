<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  let hero3dCleanup: (() => void) | null = null;
  let mm: any = null;
  let heroGen = 0;

  function initHome() {
    const root = document.querySelector('[data-page="home"]') as HTMLElement | null;
    if (!root || root.dataset.gsapInit) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData = (navigator as any).connection?.saveData === true;

    // Lazy-load the Breed Matcher iframe when it's near the viewport (content, not motion —
    // runs even for reduced-motion users).
    const frame = root.querySelector('[data-matcher-frame]') as HTMLIFrameElement | null;
    if (frame && !frame.src && frame.dataset.src && !frame.dataset.io) {
      frame.dataset.io = '1';
      const io = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              frame.src = frame.dataset.src as string;
              obs.disconnect();
            }
          });
        },
        { rootMargin: '400px' }
      );
      io.observe(frame);
    }

    if (reduceMotion) return; // static page — everything already visible
    root.dataset.gsapInit = '1';

    // WebGL hero — after first paint, never for data-saver users.
    // gen token + isConnected guard: bail if the user navigates away during the async import.
    if (!saveData) {
      const gen = ++heroGen;
      requestAnimationFrame(() => {
        if (!root.isConnected || gen !== heroGen) return;
        import('three')
          .then((THREE) => {
            if (!root.isConnected || gen !== heroGen) return;
            try {
              hero3dCleanup = initHero3D(THREE, root);
            } catch (e) {
              /* WebGL unavailable — static photo hero stands on its own */
            }
          })
          .catch(() => {});
      });
    }

    mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      /* --- Hero entrance --- */
      gsap
        .timeline({ defaults: { ease: 'power3.out' } })
        .from('[data-hero-eyebrow]', { y: 24, autoAlpha: 0, duration: 0.6 }, 0.1)
        .from('[data-hero-title] .hero-line', { y: 54, autoAlpha: 0, duration: 0.9, stagger: 0.14 }, 0.2)
        .from('[data-hero-sub]', { y: 24, autoAlpha: 0, duration: 0.7 }, 0.55)
        .from('[data-hero-cta] > *', { y: 18, autoAlpha: 0, duration: 0.55, stagger: 0.1 }, 0.72)
        .from('[data-hero-trust]', { y: 36, autoAlpha: 0, duration: 0.7 }, 0.9)
        .from('[data-hero-cue]', { autoAlpha: 0, duration: 0.6 }, 1.15);

      /* --- Hero parallax drift --- */
      gsap.to('[data-hero-media]', {
        scale: 1.12,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: 'top top', end: 'bottom top', scrub: true },
      });
      gsap.to('[data-hero-cue]', {
        autoAlpha: 0,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: '5% top', end: '20% top', scrub: true },
      });

      /* --- Generic reveals --- */
      gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
        gsap.from(el, {
          y: 36,
          autoAlpha: 0,
          duration: 0.85,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 86%', once: true },
        });
      });

      /* --- Staggered groups --- */
      gsap.utils.toArray<HTMLElement>('[data-stagger]').forEach((group) => {
        gsap.from(group.children, {
          y: 28,
          autoAlpha: 0,
          duration: 0.7,
          ease: 'power3.out',
          stagger: 0.07,
          scrollTrigger: { trigger: group, start: 'top 86%', once: true },
        });
      });
    });

    /* --- Drag-to-scroll photo rail (mouse; touch uses native scroll) --- */
    const track = root.querySelector('[data-drag-track]') as HTMLElement | null;
    if (track) {
      let down = false;
      let moved = false;
      let startX = 0;
      let startScroll = 0;
      track.addEventListener('pointerdown', (e) => {
        if (e.pointerType !== 'mouse') return;
        down = true;
        moved = false;
        startX = e.clientX;
        startScroll = track.scrollLeft;
        track.classList.add('dragging');
        track.setPointerCapture(e.pointerId);
      });
      track.addEventListener('pointermove', (e) => {
        if (!down) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        track.scrollLeft = startScroll - dx;
      });
      const release = () => {
        down = false;
        track.classList.remove('dragging');
      };
      track.addEventListener('pointerup', release);
      track.addEventListener('pointercancel', release);
      track.addEventListener(
        'click',
        (e) => {
          if (moved) {
            e.preventDefault();
            e.stopPropagation();
          }
        },
        true
      );
    }
  }

  /* ============ The WebGL "settling storm" hero (anxious → calm) ============ */
  function initHero3D(THREE: any, root: HTMLElement): (() => void) | null {
    const canvas = root.querySelector('[data-hero-canvas]') as HTMLCanvasElement | null;
    const heroSection = root.querySelector('[data-hero]') as HTMLElement | null;
    if (!canvas || !heroSection) return null;

    let renderer: any;
    try {
      renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true, powerPreference: 'low-power' });
    } catch (e) {
      return null;
    }

    const getSize = () => ({ w: heroSection.clientWidth, h: heroSection.clientHeight });
    let { w, h } = getSize();
    const pixelRatio = Math.min(window.devicePixelRatio || 1, 2);
    renderer.setPixelRatio(pixelRatio);
    renderer.setSize(w, h, false);
    renderer.setClearColor(0x000000, 0);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(55, w / h, 0.1, 100);
    camera.position.z = 6;

    const COUNT = window.innerWidth < 768 ? 1800 : 3800;
    const positions = new Float32Array(COUNT * 3);
    const offsets = new Float32Array(COUNT * 3);
    const rands = new Float32Array(COUNT);
    for (let i = 0; i < COUNT; i++) {
      // "calm" home — an upper-biased soft cloud (keeps clear of the bottom-left copy)
      positions[i * 3] = (Math.random() * 2 - 1) * 5.2;
      positions[i * 3 + 1] = (Math.random() * 2 - 1) * 2.0 + 0.9;
      positions[i * 3 + 2] = (Math.random() * 2 - 1) * 1.6;
      // "anxious" scatter direction
      offsets[i * 3] = (Math.random() * 2 - 1) * 3.4;
      offsets[i * 3 + 1] = (Math.random() * 2 - 1) * 3.0;
      offsets[i * 3 + 2] = (Math.random() * 2 - 1) * 2.4;
      rands[i] = Math.random();
    }

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    geometry.setAttribute('aOffset', new THREE.BufferAttribute(offsets, 3));
    geometry.setAttribute('aRand', new THREE.BufferAttribute(rands, 1));

    const uniforms = {
      uTime: { value: 0 },
      uCalm: { value: 0 },
      uSize: { value: 0.16 },
      uPixelRatio: { value: pixelRatio },
      uColorCool: { value: new THREE.Color('#6f8391') },
      uColorWarm: { value: new THREE.Color('#dfa854') },
    };

    const material = new THREE.ShaderMaterial({
      uniforms,
      transparent: true,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      vertexShader: `
        uniform float uTime;
        uniform float uCalm;
        uniform float uSize;
        uniform float uPixelRatio;
        uniform vec3 uColorCool;
        uniform vec3 uColorWarm;
        attribute vec3 aOffset;
        attribute float aRand;
        varying float vAlpha;
        varying vec3 vColor;
        void main() {
          vec3 scattered = position + aOffset;
          vec3 pos = mix(scattered, position, uCalm);
          float amp = mix(0.5, 0.12, uCalm);
          float ph = aRand * 6.2831853;
          pos.x += sin(uTime * 0.6 + ph) * amp;
          pos.y += cos(uTime * 0.5 + ph * 1.3) * amp;
          pos.z += sin(uTime * 0.4 + ph * 0.7) * amp;
          vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
          gl_Position = projectionMatrix * mvPosition;
          float size = uSize * (0.5 + aRand);
          gl_PointSize = size * uPixelRatio * (140.0 / -mvPosition.z);
          vColor = mix(uColorCool, uColorWarm, uCalm);
          vAlpha = mix(0.32, 0.9, uCalm) * (0.55 + 0.45 * aRand);
        }
      `,
      fragmentShader: `
        precision mediump float;
        varying float vAlpha;
        varying vec3 vColor;
        void main() {
          float d = length(gl_PointCoord - vec2(0.5));
          if (d > 0.5) discard;
          float a = smoothstep(0.5, 0.05, d);
          gl_FragColor = vec4(vColor, a * vAlpha);
        }
      `,
    });

    const points = new THREE.Points(geometry, material);
    scene.add(points);

    // Entrance: anxious (0) → calm (1)
    const calmTween = gsap.to(uniforms.uCalm, { value: 1, duration: 2.8, ease: 'power2.out', delay: 0.25 });

    // Pointer parallax
    let targetRotX = 0;
    let targetRotY = 0;
    const onPointer = (e: PointerEvent) => {
      const nx = e.clientX / window.innerWidth - 0.5;
      const ny = e.clientY / window.innerHeight - 0.5;
      targetRotY = nx * 0.3;
      targetRotX = -ny * 0.18;
    };
    heroSection.addEventListener('pointermove', onPointer);

    const onResize = () => {
      const s = getSize();
      w = s.w;
      h = s.h;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h, false);
    };
    window.addEventListener('resize', onResize);

    const clock = new THREE.Clock();
    let raf = 0;
    let running = false;
    let inView = true;
    let tabVisible = document.visibilityState !== 'hidden';
    const tick = () => {
      uniforms.uTime.value = clock.getElapsedTime();
      points.rotation.y += (targetRotY - points.rotation.y) * 0.05;
      points.rotation.x += (targetRotX - points.rotation.x) * 0.05;
      renderer.render(scene, camera);
      raf = requestAnimationFrame(tick);
    };
    // Only render when the hero is on-screen AND the tab is visible (save GPU/battery on this long page).
    const sync = () => {
      const should = inView && tabVisible;
      if (should && !running) {
        running = true;
        raf = requestAnimationFrame(tick);
      } else if (!should && running) {
        running = false;
        cancelAnimationFrame(raf);
      }
    };
    const onVis = () => {
      tabVisible = document.visibilityState !== 'hidden';
      sync();
    };
    document.addEventListener('visibilitychange', onVis);
    const io = new IntersectionObserver(
      (entries) => {
        inView = entries[0]?.isIntersecting ?? true;
        sync();
      },
      { threshold: 0 }
    );
    io.observe(heroSection);
    sync();

    return () => {
      running = false;
      cancelAnimationFrame(raf);
      calmTween.kill();
      io.disconnect();
      window.removeEventListener('resize', onResize);
      heroSection.removeEventListener('pointermove', onPointer);
      document.removeEventListener('visibilitychange', onVis);
      geometry.dispose();
      material.dispose();
      renderer.dispose();
    };
  }

  initHome();
  document.addEventListener('astro:page-load', initHome);
  document.addEventListener('astro:before-swap', () => {
    heroGen++; // invalidate any in-flight WebGL init still awaiting import('three')
    ScrollTrigger.getAll().forEach((t) => t.kill());
    if (mm) {
      mm.revert();
      mm = null;
    }
    if (hero3dCleanup) {
      hero3dCleanup();
      hero3dCleanup = null;
    }
  });
</script>
