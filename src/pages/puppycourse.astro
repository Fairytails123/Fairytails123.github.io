</Base>

<style>
  /* Chapter/phase steps: dimmed until active (JS adds .is-active). Entrances are
     x-only so this CSS keeps owning opacity (the classes-page fix — never add
     autoAlpha to these steps' entrance tweens). No-JS/reduced-motion = full. */
  .pc-step {
    transition: opacity 0.45s ease;
  }
  [data-gsap-init] .pc-step:not(.is-active) {
    opacity: 0.55;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-gsap-init] .pc-step:not(.is-active) {
      opacity: 1;
    }
  }

  /* Daily-rhythm trail (dark section) + travelling sun */
  .pc-trail {
    background: linear-gradient(to bottom, var(--color-honey-200), var(--color-honey-400) 45%, var(--color-honey-700));
  }
  .pc-sun {
    filter: drop-shadow(0 0 8px rgb(236 194 124 / 0.55));
  }

  /* Weeks trail (light section) */
  .pc-week-trail {
    background: linear-gradient(to bottom, var(--color-honey-400), var(--color-honey-600));
  }

  /* Toilet-tool segmented control (sibling of the day-school estimator's .seg) */
  .pc-seg {
    display: inline-flex;
    gap: 0.4rem;
    padding: 0.3rem;
    border-radius: 9999px;
    background: var(--color-cream-200);
  }
  .pc-seg-opt {
    position: relative;
  }
  .pc-seg-opt input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .pc-seg-opt span {
    display: block;
    cursor: pointer;
    border-radius: 9999px;
    padding: 0.5rem 1.1rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-bark-700);
    transition:
      background-color 0.25s ease,
      color 0.25s ease;
  }
  .pc-seg-opt input:checked + span {
    background: var(--color-moss-700);
    color: var(--color-cream-50);
  }
  .pc-seg-opt input:focus-visible + span {
    outline: 2px solid var(--color-honey-600);
    outline-offset: 2px;
  }

  /* Toilet-tool bars animate between ages */
  .pc-bar {
    transition: width 0.6s cubic-bezier(0.34, 1.2, 0.64, 1);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initVideoLoops } from '../scripts/videoLoops';

  gsap.registerPlugin(ScrollTrigger);

  let mm: any = null;

  function initPuppyCourse() {
    const root = document.querySelector('[data-page="puppycourse"]') as HTMLElement | null;
    if (!root || root.dataset.gsapInit) return;
    initVideoLoops(root);

    /* --- Toilet tool: content, not motion — runs for reduced-motion users too. --- */
    const tool = root.querySelector('[data-tt]') as HTMLElement | null;
    if (tool && !tool.dataset.ttInit) {
      tool.dataset.ttInit = '1';
      // Mirrors the SSR toiletTable (verbatim from the legacy toilet-schedule page).
      const DATA = [
        { day: '2 hours', night: '5 hours', dayPct: 25, nightPct: 62.5 },
        { day: '3 hours', night: '7 hours', dayPct: 37.5, nightPct: 87.5 },
        { day: '4 hours', night: '8 hours', dayPct: 50, nightPct: 100 },
      ];
      const dayEl = tool.querySelector('[data-tt-day]') as HTMLElement;
      const nightEl = tool.querySelector('[data-tt-night]') as HTMLElement;
      const dayBar = tool.querySelector('[data-tt-day-bar]') as HTMLElement;
      const nightBar = tool.querySelector('[data-tt-night-bar]') as HTMLElement;
      tool.querySelectorAll<HTMLInputElement>('input[name="tt-age"]').forEach((input) => {
        input.addEventListener('change', () => {
          const d = DATA[Number(input.value)];
          if (!d) return;
          dayEl.textContent = d.day;
          nightEl.textContent = d.night;
          dayBar.style.width = `${d.dayPct}%`;
          nightBar.style.width = `${d.nightPct}%`;
        });
      });
    }

    // Hero image parallax needs no video wiring; motion below is gated.
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion) return; // static page — everything already visible
    root.dataset.gsapInit = '1';

    mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      /* --- Hero entrance --- */
      gsap
        .timeline({ defaults: { ease: 'power3.out' } })
        .from('[data-hero-eyebrow]', { y: 24, duration: 0.6 }, 0.1)
        .from('[data-hero-title] .hero-line', { y: 24, duration: 0.9, stagger: 0.14 }, 0.2)
        .from('[data-hero-sub]', { y: 24, duration: 0.7 }, 0.55)
        .from('[data-hero-cta] > *', { y: 18, duration: 0.55, stagger: 0.1 }, 0.72)
        .from('[data-hero-trust]', { y: 36, duration: 0.7 }, 0.85)
        .from('[data-hero-cue]', { autoAlpha: 0, duration: 0.6 }, 1.1);

      /* --- Hero parallax drift --- */
      gsap.to('[data-hero-media]', {
        scale: 1.09,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: 'top top', end: 'bottom top', scrub: true },
      });
      gsap.to('[data-hero-cue]', {
        autoAlpha: 0,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: '5% top', end: '20% top', scrub: true },
      });

      /* --- Generic reveals --- */
      gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
        gsap.from(el, {
          y: 36,
          duration: 0.85,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 86%', once: true },
        });
      });

      /* --- Staggered groups --- */
      gsap.utils.toArray<HTMLElement>('[data-stagger]').forEach((group) => {
        gsap.from(group.children, {
          y: 28,
          duration: 0.7,
          ease: 'power3.out',
          stagger: 0.07,
          scrollTrigger: { trigger: group, start: 'top 86%', once: true },
        });
      });

      /* --- Signature 1: the daily rhythm — sun rises and sets down the schedule --- */
      const rhythmList = root.querySelector('[data-rhythm-list]') as HTMLElement | null;
      const rhythmFill = root.querySelector('[data-trail-fill]');
      const sun = root.querySelector('[data-trail-sun]') as HTMLElement | null;
      if (rhythmList && rhythmFill) {
        const trail = { trigger: rhythmList, start: 'top 62%', end: 'bottom 55%', scrub: 0.5 };
        gsap.fromTo(rhythmFill, { scaleY: 0 }, { scaleY: 1, ease: 'none', scrollTrigger: trail });
        if (sun) {
          gsap.fromTo(
            sun,
            { y: 0, rotation: 0 },
            {
              y: () => (sun.parentElement?.offsetHeight ?? 0) - 24,
              rotation: 60,
              ease: 'none',
              scrollTrigger: trail,
            }
          );
        }
      }

      /* --- Signature 2: the four-week chapter trail --- */
      const weekList = root.querySelector('[data-week-list]') as HTMLElement | null;
      const weekFill = root.querySelector('[data-week-fill]');
      const paw = root.querySelector('[data-week-paw]') as HTMLElement | null;
      if (weekList && weekFill) {
        const trail = { trigger: weekList, start: 'top 62%', end: 'bottom 55%', scrub: 0.5 };
        gsap.fromTo(weekFill, { scaleY: 0 }, { scaleY: 1, ease: 'none', scrollTrigger: trail });
        if (paw) {
          gsap.fromTo(
            paw,
            { y: 0, rotation: -8 },
            {
              y: () => (paw.parentElement?.offsetHeight ?? 0) - 12,
              rotation: 8,
              ease: 'none',
              scrollTrigger: trail,
            }
          );
        }
      }

      /* Step activation + entrances. X-ONLY entrances: the .pc-step dim CSS owns
         opacity — adding autoAlpha here would leave inline opacity:1 behind and
         silently defeat the dim forever (2026-07-05 lesson). */
      gsap.utils.toArray<HTMLElement>('[data-rhythm-step], [data-week-step]').forEach((step) => {
        ScrollTrigger.create({
          trigger: step,
          start: 'top 68%',
          end: 'bottom 40%',
          onToggle: (self) => step.classList.toggle('is-active', self.isActive),
        });
        gsap.from(step, {
          x: 40,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: { trigger: step, start: 'top 88%', once: true },
        });
      });
    });
  }

  initPuppyCourse();
  document.addEventListener('astro:page-load', initPuppyCourse);
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill());
    if (mm) {
      mm.revert();
      mm = null;
    }
  });
</script>
