---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import HillDivider from '../components/HillDivider.astro';
import CouncilRating from '../components/CouncilRating.astro';
import { business } from '../data/business';
import pricing from '../data/pricing.json';

// Reused real photos from the harvest (cross-folder imports are fine — Astro
// dedupes by hash). A dedicated /comprehensive-puppy-training asset folder can
// replace these if the owner wants bespoke images.
import puppyLabSit from '../assets/pages/puppy-training-classes/puppy-lab-sit.webp';
import puppyLifeSkills from '../assets/pages/puppy-training-classes/puppy-life-skills.webp';
import classesLeadWalk from '../assets/pages/puppy-training-classes/classes-lead-walk.webp';
import puppyRecall from '../assets/pages/puppy-training-classes/puppy-recall.webp';
import puppyHeadTilt from '../assets/pages/puppy-training-classes/puppy-head-tilt.webp';
import puppyTerrierGrass from '../assets/pages/puppy-training-classes/puppy-terrier-grass.webp';
import dogWalkKam from '../assets/pages/dog-boarding-school/Dog-walk-with-Kam-2880w.webp';
import puppyTown from '../assets/pages/intensive-dog-training/Puppy-Training-in-Town-2880w.webp';
import countryPark from '../assets/pages/intensive-dog-training/Intensive-Training-in-the-Country-Park-2880w.webp';
import busLab from '../assets/pages/dog-boarding-school/Black-Lab-on-the-bus-square-2-2880w.webp';
import doggyFriends from '../assets/pages/dog-day-school/doggy-friends-2880w.webp';
import buildingConfidence from '../assets/pages/dog-day-school/building-confidence-2880w.webp';
// Real-world training-in-action photos (our own training reports; head-collar/muzzle screened)
import cwHenryCafe from '../assets/pages/training-real-world/rw-cafe-henry-301777.webp';
import cwEnzoSea from '../assets/pages/training-real-world/rw-sea-enzo-092952.webp';
import cwFrankiePark from '../assets/pages/training-real-world/rw-park-frankie-498846.webp';
import cwTillySea from '../assets/pages/training-real-world/rw-sea-tilly-990468.webp';
import cwRubyTown from '../assets/pages/training-real-world/rw-town-ruby-774448.webp';
import cwAlanBus from '../assets/pages/training-real-world/rw-bus-alan-309772.webp';

const compReal = [
  { img: cwHenryCafe, name: 'Henry', caption: 'Settled under a café table' },
  { img: cwEnzoSea, name: 'Enzo', caption: 'Focused on the seafront' },
  { img: cwRubyTown, name: 'Ruby', caption: 'Settling on a town pavement' },
  { img: cwAlanBus, name: 'Alan', caption: 'Calm on the bus' },
  { img: cwFrankiePark, name: 'Frankie', caption: 'A steady sit at the park' },
  { img: cwTillySea, name: 'Tilly', caption: 'Settling by the seafront' },
];

const plan = pricing.offerings.find((o) => o.id === 'puppy-intensive');
const puppyClasses = pricing.offerings.find((o) => o.id === 'puppy-classes');
const puppyBoard = pricing.offerings.find((o) => o.id === 'board-train-puppy');

const gbp = (n) => `£${Number.isInteger(n) ? n.toLocaleString('en-GB') : n.toFixed(2)}`;

// What a trainer adds — the "more than basic obedience" cards. The last card
// carries the trainer-led vs parent-led contrast with the £175 classes (owner
// positioning, 2026-07-06).
const trainerAdds = [
  {
    title: 'We read the room',
    body: 'Our trainers read your puppy’s body language all day — knowing when to gently push and when to give space, so every new experience builds confidence instead of fear.',
  },
  {
    title: 'The right pace, all day',
    body: 'Socialisation happens at a pace that suits your puppy, with structured time on and time off, so they cope, settle and grow — never over-faced, never overtired.',
  },
  {
    title: 'Consistency you can’t fake at home',
    body: 'The same trainers, the same rules, every hour of every day. That steady repetition is what actually makes training stick — and it’s hard to reproduce around family life.',
  },
  {
    title: 'We do the heavy lifting',
    body: 'This is the real difference from a weekly class: in classes we teach you and you put in the work at home. Here your puppy spends full days with us and we do the training for you.',
  },
];

// SIGNATURE: managed socialisation as a rhythm of "time on" (play/learning) and
// "time off" (rest). DRAFT copy — owner to fine-tune on the preview.
const rhythm = [
  { on: true, phase: 'Time on', title: 'Arrive & tune in', body: 'A calm hello and a good sniff. We read your puppy’s mood before anything else begins.' },
  { on: false, phase: 'Time off', title: 'Settle first', body: 'Before any fun, a moment of quiet. A puppy that can settle is a puppy that can learn.' },
  { on: true, phase: 'Time on', title: 'The right introductions', body: 'Structured play with carefully chosen friends — different breeds, sizes and temperaments, always supervised.' },
  { on: false, phase: 'Time off', title: 'Rest & reset', body: 'Down-time in their own space. This is where confidence actually sets in — short bursts, then proper recovery.' },
  { on: true, phase: 'Time on', title: 'A taste of the world', body: 'A little training and a new experience woven in — a new surface, a new sound, a new face.' },
  { on: false, phase: 'Time off', title: 'Wind down for home', body: 'Brains full, tails wagging. They go home tired in the best way, ready to do it all again tomorrow.' },
];

// What your puppy learns out in the real world.
const worldSkills = [
  'Good loose-lead walking — no dragging, no zig-zag',
  'Coming back when called, even with distractions',
  'Calm, polite manners in cafés, shops and on public transport',
  'Confidence around traffic, crowds, other dogs and new surfaces',
  'Appropriate play — and learning when it’s time to stop',
];

// The shape of the month. DRAFT — owner to supply the real week-by-week on the preview.
const monthPlan = [
  { week: 'Week 1', title: 'Settle & assess', body: 'Your puppy moves into the rhythm of full-day school. We get to know them and they get to know us — routine and trust come first.' },
  { week: 'Week 2', title: 'Socialise & explore', body: 'Structured introductions ramp up, first outings into the quieter corners of the real world, and overnight stays begin — gently.' },
  { week: 'Week 3', title: 'Out into the world', body: 'Busier places — a café, a short bus ride, a livelier park — with loose-lead walking and recall growing stronger every day.' },
  { week: 'Week 4', title: 'Consolidate & hand over', body: 'Everything comes together, and we coach you: the cues, the timing and the habits that keep it all going once your puppy is home for good.' },
];

// What the month includes — marketing copy (NOT price facts, which live in pricing.json).
const includes = [
  'Full days of trainer-led training and socialisation',
  'Structured introductions to all breeds, shapes and sizes',
  'Real-world outings — towns, cafés, transport and busy parks',
  'Overnight stays to head off separation anxiety',
  'An end-of-month handover so the training sticks at home',
];

// The pay-off.
const benefits = [
  { title: 'A confident dog', body: 'Early, expert exposure builds a puppy that meets the world calmly instead of fearing it.' },
  { title: 'Confident when left alone', body: 'A puppy taught early to settle without you grows into a dog you can leave — calmly, without the guilt, the chewed door frames, or the upset neighbours.' },
  { title: 'Genuinely well-socialised', body: 'Not just “friendly” — a puppy that reads other dogs, plays fairly and knows when to settle.' },
  { title: 'Habits that hold', body: 'The foundations are laid right the first time, so you’re not un-teaching bad habits for years.' },
];

// Eligibility for a mid-vaccination puppy (differs from the classes' "under 6 months").
const entryRules = [
  'Best for local puppies from their second set of vaccinations, up to around 18 weeks old.',
  'Vaccinations in progress or up to date — DHP, Leptospirosis and Kennel Cough (the same set our day school asks for). If your pup is mid-course, get in touch and we’ll plan the right start date.',
  'A short chat or free consult first, so we can build the month around your puppy — and be honest if a different route would suit them better.',
];

// DRAFT FAQs — conservative, enquiry-first answers (flagged for owner review).
const faqs = [
  {
    q: 'When can my puppy start?',
    a: 'As early as it’s safe to — from their second set of vaccinations. The early weeks are a one-time window, and the sooner we start, the less there is to un-teach later. If your puppy is mid-vaccination, book a chat and we’ll plan the right start date together.',
  },
  {
    q: 'How is this different from your puppy classes?',
    a: 'Puppy Training Classes are a weekly evening course where we teach you and you put in the work at home — brilliant value at £175. This is full-day, trainer-led training: your puppy spends whole days with us and we do the heavy lifting. Plenty of owners do both.',
  },
  {
    q: 'How is it different from Board & Train?',
    a: 'Board & Train is residential — your dog lives with us — and is often the right call for older dogs or serious behavioural issues. This is full-day puppy school with overnight stays woven in for the separation-anxiety work, so your pup is home with you most nights.',
  },
  {
    q: 'Will the overnight stays upset my puppy?',
    a: 'No — that’s rather the point. Stays are gentle, gradual and in good company, and they teach your puppy that being apart from you is nothing to fear. Preventing separation anxiety now is far kinder than trying to fix it later.',
  },
  {
    q: 'Is my puppy too young, or too nervous?',
    a: 'The earlier the better, and nervous pups often benefit most — we simply pace everything to suit them. If we honestly feel a different route would be kinder, we’ll say so.',
  },
  {
    q: 'What happens after the month?',
    a: 'We hand the training over to you so it sticks, and many puppies carry on with day-school days to keep their socialisation and confidence topped up. We’ll talk you through the options.',
  },
];
---

<Base
  title="Comprehensive Puppy Training in Hastings & St Leonards | The Fairy Tails"
  description="Full-day, trainer-led puppy training and structured socialisation in Hastings & St Leonards. We build real-world confidence and help prevent separation anxiety."
  path="/comprehensive-puppy-training"
>
  <div data-page="comprehensive-puppy">
    <!-- ============ HERO ============ -->
    <section class="relative isolate flex min-h-[92svh] items-end overflow-hidden bg-pine-950" data-hero>
      <div class="absolute inset-0 -z-10 overflow-hidden">
        <!-- TODO(owner): swap in a bespoke full-day / trainer-led puppy clip.
             Interim reuse of the live puppy clip (owner-approved), per the
             pre-build interview 2026-07-06. Poster = reduced-motion fallback. -->
        <video
          class="h-full w-full object-cover"
          poster="/media/puppy-classes-poster.jpg"
          muted
          loop
          playsinline
          preload="none"
          data-hero-video
          data-hero-media
          aria-hidden="true"
        >
          <source src="/media/puppy-classes-hero.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-t from-pine-950/95 via-pine-950/45 to-pine-950/25"></div>
      </div>

      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-36 sm:pb-28">
        <p class="eyebrow text-honey-300" data-hero-eyebrow>Comprehensive Puppy Training · Full-day puppy school in Hastings</p>
        <h1 class="mt-4 max-w-3xl font-display text-[2.6rem] font-bold leading-[1.05] text-cream-50 sm:text-6xl" data-hero-title>
          <span class="hero-line block">A month that shapes</span>
          <span class="hero-line block">the <em class="squiggle not-italic">rest of their life</em></span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-cream-100/90" data-hero-sub>
          One month of full-day, trainer-led training and structured socialisation — we introduce your
          puppy to the world so they grow up confident, settled and easy to live with. For local pups
          from their second vaccinations, up to 18 weeks.
        </p>
        <div class="mt-9 flex flex-wrap gap-4" data-hero-cta>
          <a href="#enquire" class="btn btn-honey">
            Send an enquiry <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <a href={business.acuity.freeConsult} class="btn btn-ghost-light">Book a free consult</a>
        </div>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-cream-100/70" data-hero-cue aria-hidden="true">
        <svg width="22" height="30" viewBox="0 0 22 30" fill="none" class="animate-bounce">
          <rect x="1" y="1" width="20" height="28" rx="10" stroke="currentColor" stroke-width="2"></rect>
          <circle cx="11" cy="10" r="3" fill="currentColor"></circle>
        </svg>
      </div>
    </section>

    <!-- Trust strip — overlaps the hero -->
    <div class="relative z-10 mx-auto -mt-12 max-w-5xl px-4" data-hero-trust>
      <ul class="grain grid gap-4 rounded-2xl bg-cream-50 px-7 py-6 text-sm font-bold text-bark-700 shadow-[var(--shadow-polaroid)] sm:grid-cols-3 sm:gap-2">
        <li class="paw-bullet flex items-center text-moss-700">Full days with our trainers — we do the hard work</li>
        <li class="paw-bullet flex items-center text-moss-700">Socialised with all breeds, shapes and sizes</li>
        <li class="paw-bullet flex items-center text-moss-700">Overnight stays that head off separation anxiety</li>
      </ul>
    </div>

    <!-- ============ WHY START NOW — the window ============ -->
    <section class="mx-auto max-w-6xl px-4 py-20 sm:py-28" data-section="window">
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <p class="eyebrow text-honey-600" data-reveal>Start as early as it’s safe</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
            A window that <em class="squiggle not-italic">won’t come back</em>
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-bark-700" data-reveal>
            The best time to train a puppy is as soon as it’s safe to start — right from the get-go.
            Those early weeks are a one-time developmental window: a blank canvas, when your puppy soaks
            up the world faster than they ever will again.
          </p>
          <p class="mt-4 leading-relaxed text-bark-700" data-reveal>
            The longer training is delayed, the harder it becomes to break old habits. Starting from your
            puppy’s second set of vaccinations gives them the best possible chance of growing into a
            confident, well-behaved dog — and a month of expert work now saves you months of correction
            later.
          </p>
        </div>
        <figure class="polaroid mx-auto w-full max-w-sm" style="transform: rotate(-2deg);" data-reveal>
          <Image
            src={puppyLabSit}
            alt="Tilly, a young shepherd puppy, settling calmly by the seafront"
            class="aspect-[4/5] w-full rounded-[2px] object-cover"
            widths={[480, 960]}
            sizes="(min-width: 1024px) 24rem, 90vw"
          />
          <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">
            A blank canvas — let’s make it count
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- ============ MORE THAN BASIC OBEDIENCE ============ -->
    <section class="bg-cream-100" data-section="more">
      <HillDivider class="bg-cream-50 text-cream-100" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <div class="grid items-end gap-8 lg:grid-cols-[1.1fr_0.9fr]">
          <div>
            <p class="eyebrow text-honey-600" data-reveal>More than sit and stay</p>
            <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
              Not just obedience — <em class="squiggle not-italic">a proper education</em>
            </h2>
            <p class="mt-5 max-w-xl text-lg leading-relaxed text-bark-700" data-reveal>
              Basic obedience and a bit of socialising in the park are a good start. Comprehensive puppy
              training is something more: a professional introducing your puppy to the world from an
              expert’s point of view — carefully, at the right pace, all day long.
            </p>
          </div>
          <figure class="polaroid mx-auto w-full max-w-[17rem]" style="transform: rotate(2.5deg);" data-reveal>
            <Image
              src={dogWalkKam}
              alt="A Fairy Tails trainer walking a dog on a loose lead through the countryside"
              class="aspect-[4/5] w-full rounded-[2px] object-cover"
              widths={[360, 720]}
              sizes="17rem"
            />
            <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">
              Led by trainers, every step
            </figcaption>
          </figure>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {
            trainerAdds.map((c) => (
              <article class="grain flex flex-col rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)] transition-transform duration-300 hover:-translate-y-1.5">
                <h3 class="font-display text-lg font-bold text-moss-800">{c.title}</h3>
                <p class="mt-2.5 text-sm leading-relaxed text-bark-700">{c.body}</p>
              </article>
            ))
          }
        </div>

        <p class="mt-8 rounded-2xl bg-cream-50 p-6 leading-relaxed text-bark-700 shadow-[var(--shadow-lift)]" data-reveal>
          <strong class="text-moss-800">Prefer to do the training yourself?</strong> Our
          <a href="/puppy-training-classes" class="font-bold text-moss-700 underline decoration-honey-400 decoration-2 underline-offset-2">group puppy classes</a>
          teach you how, for {gbp(puppyClasses.price)} — you put in the homework. This page is for owners
          who’d rather we did the hard work, full-time.
        </p>
      </div>
    </section>

    <!-- ============ SIGNATURE: TIME ON, TIME OFF ============ -->
    <section class="relative overflow-hidden bg-pine-950 text-cream-100" data-section="rhythm">
      <HillDivider class="relative z-10 bg-cream-100 text-pine-950" flip />
      <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-2/3" aria-hidden="true" style="background: radial-gradient(60% 50% at 78% 0%, rgba(236,194,124,0.14), transparent 70%), radial-gradient(70% 55% at 20% 100%, rgba(245,238,221,0.08), transparent 72%);"></div>

      <div class="relative z-10 mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-400" data-reveal>Managed socialisation</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-cream-50 sm:text-4xl" data-reveal>
          Confidence is built in <em class="squiggle not-italic">rhythm</em>
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-cream-200" data-reveal>
          Good socialisation is never a free-for-all. We introduce your puppy to different breeds, sizes
          and playmates in short, structured bursts — <strong class="text-honey-300">time on</strong> —
          followed by proper rest — <strong class="text-honey-300">time off</strong> — so they learn to
          cope, settle, and come back for more. Here’s the rhythm of a session.
        </p>

        <!-- The rhythm: a trail fills + a marker travels as you scroll -->
        <div class="relative mt-14 overflow-x-clip" data-rhythm-list>
          <div class="absolute bottom-4 left-[15px] top-2 w-0.5 sm:left-[110px]" aria-hidden="true">
            <div class="absolute inset-0 rounded bg-pine-800"></div>
            <div class="rhythm-trail absolute inset-0 origin-top rounded" data-trail-fill></div>
            <span class="rhythm-marker absolute -left-[13px] top-0 block h-7 w-7" data-trail-marker>
              <svg viewBox="0 0 28 28" fill="none" class="h-full w-full">
                <circle cx="14" cy="14" r="7" fill="var(--color-honey-300)"></circle>
                <circle cx="14" cy="14" r="11" stroke="var(--color-honey-300)" stroke-width="1.5" opacity="0.5"></circle>
              </svg>
            </span>
          </div>

          <ol class="space-y-10 sm:space-y-12">
            {
              rhythm.map((step) => (
                <li class="rhythm-step relative grid gap-2 pl-9 sm:grid-cols-[84px_1fr] sm:gap-12 sm:pl-0" data-rhythm-step>
                  <p
                    class:list={[
                      'font-display text-xs font-bold uppercase tracking-[0.12em] sm:text-right',
                      step.on ? 'text-honey-400' : 'text-cream-300',
                    ]}
                  >
                    {step.phase}
                  </p>
                  <div class="sm:pl-14">
                    <h3 class="font-display text-2xl font-bold text-cream-50">{step.title}</h3>
                    <p class="mt-2 max-w-2xl leading-relaxed text-cream-200">{step.body}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>

        <div class="mt-14 grid items-center gap-8 rounded-2xl bg-pine-900 p-6 sm:grid-cols-[1fr_auto] sm:p-8" data-reveal>
          <p class="leading-relaxed text-cream-100">
            <strong class="text-honey-300">Why the rest matters as much as the play:</strong> a puppy
            learns to be confident when it’s never over-faced and never overtired. The “time off” is where
            the growing actually happens — it’s the part most owners skip, and the part we build in.
          </p>
          <figure class="mx-auto w-40 shrink-0 overflow-hidden rounded-xl sm:w-44">
            <Image src={doggyFriends} alt="Two puppies of different breeds playing together under supervision" class="aspect-square w-full object-cover" widths={[176, 352]} sizes="11rem" />
          </figure>
        </div>
      </div>
    </section>

    <!-- ============ BOARDING THAT PREVENTS SEPARATION ANXIETY ============ -->
    <section class="bg-moss-800 text-cream-100" data-section="independence">
      <HillDivider class="bg-pine-950 text-moss-800" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <figure class="polaroid mx-auto w-full max-w-[15rem] sm:max-w-[17rem]" style="transform: rotate(-2deg);" data-reveal>
            <video
              class="aspect-[9/16] w-full rounded-[2px] object-cover"
              muted
              loop
              playsinline
              preload="none"
              poster="/media/puppy-settle-poster.jpg"
              data-src="/media/puppy-settle-loop.mp4"
              aria-label="A golden retriever puppy settling calmly on its own"
            ></video>
            <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-cream-100">
              Calm and content on their own
            </figcaption>
          </figure>
          <div>
            <p class="eyebrow text-honey-300" data-reveal>Time apart, on purpose</p>
            <h2 class="mt-3 font-display text-3xl font-bold text-cream-50 sm:text-4xl" data-reveal>
              Learning to be <em class="squiggle not-italic">alone and okay</em>
            </h2>
            <p class="mt-5 leading-relaxed text-cream-100" data-reveal>
              One of the kindest things you can teach a young puppy is that being apart from you is nothing
              to fear. Overnight stays with us, woven into the month, teach your puppy to settle without
              you — calmly, in good company.
            </p>
            <p class="mt-4 leading-relaxed text-cream-100" data-reveal>
              It matters more than most people realise. Separation anxiety is one of the hardest
              behaviours to fix once it takes hold, and one of the biggest reasons puppies are given up.
              Left unchecked, it can leave owners feeling like prisoners of their own dog — unable to leave
              the house without a scene — and it’s rarely fair on the neighbours either. Prevention now is
              far kinder, and far easier, than a cure later.
            </p>
            <div class="mt-7 rounded-2xl bg-moss-900/60 p-6" data-reveal>
              <CouncilRating licence={true} size="md" />
              <p class="mt-4 leading-relaxed text-cream-100">
                Our overnight stays are on fully licensed premises. For dogs who already struggle with
                separation, our residential
                <a href="/dog-boarding-school" class="font-bold text-honey-300 underline decoration-honey-500 underline-offset-2">Board &amp; Train</a>
                tackles it head-on — <a href="/archiestory" class="font-bold text-honey-300 underline decoration-honey-500 underline-offset-2">Archie’s story</a>
                is a good example.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ INTO THE WORLD, AT THEIR PACE ============ -->
    <section data-section="world">
      <HillDivider class="bg-moss-800 text-cream-50" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-600" data-reveal>Real-world socialisation</p>
        <h2 class="mt-3 max-w-3xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
