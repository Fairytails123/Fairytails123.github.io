<style>
  /* Regime steps: dimmed until active (JS adds .is-active; no-JS/reduced-motion = full) */
  .regime-step {
    transition: opacity 0.45s ease;
  }
  [data-gsap-init] .regime-step:not(.is-active) {
    opacity: 0.38;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-gsap-init] .regime-step:not(.is-active) {
      opacity: 1;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initIntensive() {
    const root = document.querySelector('[data-page="intensive"]') as HTMLElement | null;
    if (!root || root.dataset.gsapInit) return;

    // Hero video: lazy-start after load; never for reduced-motion or data-saver users.
    const video = root.querySelector('[data-hero-video]') as HTMLVideoElement | null;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData = (navigator as any).connection?.saveData === true;
    if (video && !reduceMotion && !saveData) {
      setTimeout(() => {
        video.load();
        video.play().catch(() => {});
      }, 350);
    }

    if (reduceMotion) return; // static page — everything already visible
    root.dataset.gsapInit = '1';

    const mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      /* --- Hero entrance --- */
      gsap
        .timeline({ defaults: { ease: 'power3.out' } })
        .from('[data-hero-eyebrow]', { y: 24, autoAlpha: 0, duration: 0.6 }, 0.1)
        .from('[data-hero-title] .hero-line', { y: 54, autoAlpha: 0, duration: 0.9, stagger: 0.14 }, 0.2)
        .from('[data-hero-sub]', { y: 24, autoAlpha: 0, duration: 0.7 }, 0.55)
        .from('[data-hero-cta] > *', { y: 18, autoAlpha: 0, duration: 0.55, stagger: 0.1 }, 0.72)
        .from('[data-hero-trust]', { y: 36, autoAlpha: 0, duration: 0.7 }, 0.85)
        .from('[data-hero-cue]', { autoAlpha: 0, duration: 0.6 }, 1.1);

      /* --- Hero parallax drift --- */
      gsap.to('[data-hero-media]', {
        scale: 1.09,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: 'top top', end: 'bottom top', scrub: true },
      });
      gsap.to('[data-hero-cue]', {
        autoAlpha: 0,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: '5% top', end: '20% top', scrub: true },
      });

      /* --- Generic reveals --- */
      gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
        gsap.from(el, {
          y: 36,
          autoAlpha: 0,
          duration: 0.85,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 86%', once: true },
        });
      });

      /* --- Staggered groups --- */
      gsap.utils.toArray<HTMLElement>('[data-stagger]').forEach((group) => {
        gsap.from(group.children, {
          y: 28,
          autoAlpha: 0,
          duration: 0.7,
          ease: 'power3.out',
          stagger: 0.07,
          scrollTrigger: { trigger: group, start: 'top 86%', once: true },
        });
      });

      /* --- Signature: the week-by-week walk --- */
      const list = root.querySelector('[data-regime-list]') as HTMLElement | null;
      const fill = root.querySelector('[data-trail-fill]');
      const paw = root.querySelector('[data-trail-paw]') as HTMLElement | null;
      if (list && fill) {
        const trail = {
          trigger: list,
          start: 'top 62%',
          end: 'bottom 55%',
          scrub: 0.5,
        };
        gsap.fromTo(fill, { scaleY: 0 }, { scaleY: 1, ease: 'none', scrollTrigger: trail });
        if (paw) {
          gsap.fromTo(
            paw,
            { y: 0, rotation: -8 },
            {
              y: () => (paw.parentElement?.offsetHeight ?? 0) - 12,
              rotation: 8,
              ease: 'none',
              scrollTrigger: trail,
            }
          );
        }
      }
      gsap.utils.toArray<HTMLElement>('[data-regime-step]').forEach((step) => {
        ScrollTrigger.create({
          trigger: step,
          start: 'top 68%',
          end: 'bottom 40%',
          onToggle: (self) => step.classList.toggle('is-active', self.isActive),
        });
        gsap.from(step, {
          x: 40,
          autoAlpha: 0,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: { trigger: step, start: 'top 88%', once: true },
        });
      });
    });

    /* --- Drag-to-scroll polaroid rail (mouse; touch uses native scroll) --- */
    const track = root.querySelector('[data-drag-track]') as HTMLElement | null;
    if (track) {
      let down = false;
      let moved = false;
      let startX = 0;
      let startScroll = 0;
      track.addEventListener('pointerdown', (e) => {
        if (e.pointerType !== 'mouse') return;
        down = true;
        moved = false;
        startX = e.clientX;
        startScroll = track.scrollLeft;
        track.classList.add('dragging');
        track.setPointerCapture(e.pointerId);
      });
      track.addEventListener('pointermove', (e) => {
        if (!down) return;
        const dx = e.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        track.scrollLeft = startScroll - dx;
      });
      const release = () => {
        down = false;
        track.classList.remove('dragging');
      };
      track.addEventListener('pointerup', release);
      track.addEventListener('pointercancel', release);
      track.addEventListener(
        'click',
        (e) => {
          if (moved) {
            e.preventDefault();
            e.stopPropagation();
          }
        },
        true
      );
    }
  }

  initIntensive();
  document.addEventListener('astro:page-load', initIntensive);
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill());
  });
</script>
