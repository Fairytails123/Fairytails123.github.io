<style>
  /* Day-in-the-life steps: dimmed until active (JS adds .is-active; no-JS/reduced-motion = full) */
  .day-step {
    transition: opacity 0.45s ease;
  }
  [data-gsap-init] .day-step:not(.is-active) {
    opacity: 0.38;
  }

  /* Day timeline — dawn-to-dusk trail + travelling sun */
  .day-trail {
    background: linear-gradient(to bottom, var(--color-honey-200), var(--color-honey-400) 45%, var(--color-honey-700));
  }
  .day-sun {
    filter: drop-shadow(0 0 8px rgb(236 194 124 / 0.55));
  }

  /* Why-us icon hover micro-interaction */
  .why-icon {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .why-card:hover .why-icon {
    transform: scale(1.08) rotate(-6deg);
  }

  /* Estimator — segmented controls */
  .seg {
    display: inline-flex;
    margin-top: 0.5rem;
    gap: 0.4rem;
    padding: 0.3rem;
    border-radius: 9999px;
    background: var(--color-cream-100);
  }
  .seg-opt input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .seg-opt span {
    display: block;
    cursor: pointer;
    border-radius: 9999px;
    padding: 0.5rem 1.1rem;
    font-weight: 700;
    color: var(--color-bark-500);
    transition: background-color 0.25s ease, color 0.25s ease;
  }
  .seg-opt input:checked + span {
    background: var(--color-honey-400);
    color: var(--color-bark-900);
    box-shadow: var(--shadow-lift);
  }
  .seg-opt input:focus-visible + span {
    outline: 2px solid var(--color-moss-500);
    outline-offset: 2px;
  }

  /* Estimator — range slider */
  .est-range {
    margin-top: 0.6rem;
    accent-color: var(--color-honey-500);
  }

  /* Estimator — switch */
  .switch {
    cursor: pointer;
  }
  .switch input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .switch-track {
    position: relative;
    display: inline-block;
    height: 26px;
    width: 46px;
    flex: none;
    border-radius: 9999px;
    background: var(--color-cream-300);
    transition: background-color 0.25s ease;
  }
  .switch-thumb {
    position: absolute;
    left: 3px;
    top: 3px;
    height: 20px;
    width: 20px;
    border-radius: 9999px;
    background: #fff;
    box-shadow: 0 1px 3px rgb(43 37 30 / 0.35);
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .switch input:checked + .switch-track {
    background: var(--color-moss-500);
  }
  .switch input:checked + .switch-track .switch-thumb {
    transform: translateX(20px);
  }
  .switch input:focus-visible + .switch-track {
    outline: 2px solid var(--color-moss-500);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-gsap-init] .day-step:not(.is-active) {
      opacity: 1;
    }
    .seg-opt span,
    .switch-track,
    .switch-thumb,
    .why-icon {
      transition: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ---- Interactive cost estimator (core functionality — runs regardless of motion pref) ----
  function initEstimator(root: HTMLElement) {
    const est = root.querySelector('[data-estimator]') as HTMLElement | null;
    if (!est) return;
    const d = est.dataset;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const money = (n: number) => `£${Number.isInteger(n) ? n.toLocaleString('en-GB') : n.toFixed(2)}`;
    const pounds = (n: number) => `£${Math.round(n).toLocaleString('en-GB')}`;
    const get = (sel: string) => est.querySelector(sel) as HTMLElement | null;

    // Count the figures up to their new value (instant under reduced motion).
    const proxies = { perDay: { v: 0 }, week: { v: 0 }, month: { v: 0 } };
    let first = true;
    const animateTo = (el: HTMLElement | null, proxy: { v: number }, to: number, fmt: (n: number) => string) => {
      if (!el) return;
      if (reduce || first) {
        proxy.v = to;
        el.textContent = fmt(to);
        return;
      }
      gsap.to(proxy, {
        v: to,
        duration: 0.45,
        ease: 'power2.out',
        overwrite: true,
        onUpdate: () => (el.textContent = fmt(proxy.v)),
      });
    };

    const update = () => {
      const type = (est.querySelector('input[name="est-type"]:checked') as HTMLInputElement)?.value || 'full';
      const size = (est.querySelector('input[name="est-size"]:checked') as HTMLInputElement)?.value || 'standard';
      const days = Number((est.querySelector('input[name="est-days"]') as HTMLInputElement)?.value || 3);
      const weekly = (est.querySelector('input[name="est-weekly"]') as HTMLInputElement)?.checked;
      const sniffari = (est.querySelector('input[name="est-sniffari"]') as HTMLInputElement)?.checked;
      const pickup = (est.querySelector('input[name="est-pickup"]') as HTMLInputElement)?.checked;
      const dropoff = (est.querySelector('input[name="est-dropoff"]') as HTMLInputElement)?.checked;

      const base = type === 'full' ? Number(d.full) : Number(d.half);
      const wk = type === 'full' ? Number(d.fullWeekly) : Number(d.halfWeekly);
      const large = type === 'full' ? Number(d.fullLarge) : Number(d.halfLarge);

      const perDay = (weekly ? wk : base) + (size === 'large' ? large : 0);
      // Optional extras, all per attended day: Sniffari walk is per day; each of
      // pick-up and drop-off is one journey per day.
      const extrasPerDay =
        (sniffari ? Number(d.sniffari) : 0) +
        (pickup ? Number(d.pickup) : 0) +
        (dropoff ? Number(d.dropoff) : 0);
      const extrasWeek = extrasPerDay * days;
      const week = perDay * days + extrasWeek;
      const month = (week * 52) / 12;

      animateTo(get('[data-est-perday]'), proxies.perDay, perDay, money);
      animateTo(get('[data-est-week]'), proxies.week, week, money);
      animateTo(get('[data-est-month]'), proxies.month, month, pounds);

      const extrasRow = get('[data-est-extras-row]');
      const extrasOut = get('[data-est-extras]');
      if (extrasRow) extrasRow.style.display = extrasWeek > 0 ? '' : 'none';
      if (extrasOut) extrasOut.textContent = `+${money(extrasWeek)}/week`;

      // Flexi Pass note: relevant only to non-weekly clients; full days only,
      // so it washes out (stays visible but dimmed) on Half day.
      const flexiNote = get('[data-est-flexi]');
      if (flexiNote) {
        flexiNote.style.display = weekly ? 'none' : '';
        flexiNote.style.opacity = type === 'half' ? '0.3' : '1';
      }

      const daysOut = get('[data-est-days-out]');
      const hint = get('[data-est-hint]') as HTMLElement | null;
      if (daysOut) daysOut.textContent = `${days} ${days === 1 ? 'day' : 'days'}`;
      if (hint) hint.style.visibility = weekly ? 'hidden' : 'visible';
      first = false;
    };

    est.querySelectorAll('input').forEach((i) => {
      i.addEventListener('input', update);
      i.addEventListener('change', update);
    });
    update();
  }

  // ---- Drag-to-scroll polaroid rail (mouse; touch uses native scroll) ----
  function initDragRail(root: HTMLElement) {
    const track = root.querySelector('[data-drag-track]') as HTMLElement | null;
    if (!track) return;
    let down = false;
    let moved = false;
    let startX = 0;
    let startScroll = 0;
    track.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse') return;
      down = true;
      moved = false;
      startX = e.clientX;
      startScroll = track.scrollLeft;
      track.classList.add('dragging');
      track.setPointerCapture(e.pointerId);
    });
    track.addEventListener('pointermove', (e) => {
      if (!down) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 4) moved = true;
      track.scrollLeft = startScroll - dx;
    });
    const release = () => {
      down = false;
      track.classList.remove('dragging');
    };
    track.addEventListener('pointerup', release);
    track.addEventListener('pointercancel', release);
    track.addEventListener(
      'click',
      (e) => {
        if (moved) {
          e.preventDefault();
          e.stopPropagation();
        }
      },
      true
    );
  }

  function initDaySchool() {
    const root = document.querySelector('[data-page="day-school"]') as HTMLElement | null;
    if (!root || root.dataset.init) return;
    root.dataset.init = '1';

    // Core, always-on (work under reduced motion too):
    initEstimator(root);
    initDragRail(root);

    // Hero video: lazy-start after load; never for reduced-motion or data-saver users.
    const video = root.querySelector('[data-hero-video]') as HTMLVideoElement | null;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const saveData = (navigator as any).connection?.saveData === true;
    if (video && !reduceMotion && !saveData) {
      setTimeout(() => {
        video.load();
        video.play().catch(() => {});
      }, 350);
    }

    if (reduceMotion) return; // static page — everything already visible
    root.dataset.gsapInit = '1';

    const mm = gsap.matchMedia();
    mm.add('(prefers-reduced-motion: no-preference)', () => {
      /* --- Hero entrance --- */
      gsap
        .timeline({ defaults: { ease: 'power3.out' } })
        .from('[data-hero-eyebrow]', { y: 24, autoAlpha: 0, duration: 0.6 }, 0.1)
        .from('[data-hero-title] .hero-line', { y: 54, autoAlpha: 0, duration: 0.9, stagger: 0.14 }, 0.2)
        .from('[data-hero-sub]', { y: 24, autoAlpha: 0, duration: 0.7 }, 0.55)
        .from('[data-hero-cta] > *', { y: 18, autoAlpha: 0, duration: 0.55, stagger: 0.1 }, 0.72)
        .from('[data-hero-trust]', { y: 36, autoAlpha: 0, duration: 0.7 }, 0.85)
        .from('[data-hero-cue]', { autoAlpha: 0, duration: 0.6 }, 1.1);

      /* --- Hero parallax drift --- */
      gsap.to('[data-hero-media]', {
        scale: 1.09,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: 'top top', end: 'bottom top', scrub: true },
      });
      gsap.to('[data-hero-cue]', {
        autoAlpha: 0,
        ease: 'none',
        scrollTrigger: { trigger: '[data-hero]', start: '5% top', end: '20% top', scrub: true },
      });

      /* --- Generic reveals --- */
      gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
        gsap.from(el, {
          y: 36,
          autoAlpha: 0,
          duration: 0.85,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 86%', once: true },
        });
      });

      /* --- Staggered groups --- */
      gsap.utils.toArray<HTMLElement>('[data-stagger]').forEach((group) => {
        gsap.from(group.children, {
          y: 28,
          autoAlpha: 0,
          duration: 0.7,
          ease: 'power3.out',
          stagger: 0.07,
          scrollTrigger: { trigger: group, start: 'top 86%', once: true },
        });
      });

      /* --- Signature: a day in the life (the sun rises and sets down the day) --- */
      const list = root.querySelector('[data-day-list]') as HTMLElement | null;
      const fill = root.querySelector('[data-trail-fill]');
      const sun = root.querySelector('[data-trail-sun]') as HTMLElement | null;
      if (list && fill) {
        const trail = { trigger: list, start: 'top 62%', end: 'bottom 55%', scrub: 0.5 };
        gsap.fromTo(fill, { scaleY: 0 }, { scaleY: 1, ease: 'none', scrollTrigger: trail });
        if (sun) {
          gsap.fromTo(
            sun,
            { y: 0, rotation: 0 },
            {
              y: () => (sun.parentElement?.offsetHeight ?? 0) - 24,
              rotation: 60,
              ease: 'none',
              scrollTrigger: trail,
            }
          );
        }
      }
      gsap.utils.toArray<HTMLElement>('[data-day-step]').forEach((step) => {
        ScrollTrigger.create({
          trigger: step,
          start: 'top 68%',
          end: 'bottom 40%',
          onToggle: (self) => step.classList.toggle('is-active', self.isActive),
        });
        gsap.from(step, {
          x: 40,
          autoAlpha: 0,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: { trigger: step, start: 'top 88%', once: true },
        });
      });
    });
  }

  initDaySchool();
  document.addEventListener('astro:page-load', initDaySchool);
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill());
  });
</script>
