---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import EnquiryForm from '../components/EnquiryForm.astro';
import HillDivider from '../components/HillDivider.astro';
import { business } from '../data/business';
import pricing from '../data/pricing.json';

import doggyFriends from '../assets/pages/dog-day-school/doggy-friends-2880w.webp';
import enrichmentWoods from '../assets/pages/dog-day-school/enrichment-2-2880w.webp';
import climbingFrame from '../assets/pages/dog-day-school/dog-in-climbing-frame-2880w.webp';
import dogFocusing from '../assets/pages/dog-day-school/dog-focusing-2880w.webp';
import dayReport from '../assets/pages/dog-day-school/day-school-report-1920w.webp';
import cbsReport from '../assets/pages/dog-day-school/cbs-report-1920w.webp';
import happyWalk from '../assets/pages/dog-day-school/happy-walk-2880w.webp';
import onTheBeach from '../assets/pages/dog-day-school/on-the-beach-2880w.webp';
import buildingConfidence from '../assets/pages/dog-day-school/building-confidence-2880w.webp';
import onTheBus from '../assets/pages/dog-day-school/on-the-bus-1920w.webp';
import readyForSchool from '../assets/pages/dog-day-school/ready-for-school-2880w.webp';
import theBarn from '../assets/pages/dog-day-school/the-barn-1920w.webp';

import iconBuddies from '../assets/pages/dog-day-school/icon-buddies.svg';
import iconBus from '../assets/pages/dog-day-school/icon-bus.svg';
import iconEntrance from '../assets/pages/dog-day-school/icon-entrance.svg';
import iconLove from '../assets/pages/dog-day-school/icon-love.svg';

// Day-school attendance plans (PM half day removed at the 2026-06-29 interview).
const dayPlans = pricing.offerings
  .filter((o) => o.category === 'day-school' && (o.id === 'day-full' || o.id === 'day-half-am'))
  .sort((a, b) => a.order - b.order);
const fullPlan = pricing.offerings.find((o) => o.id === 'day-full');
const halfPlan = pricing.offerings.find((o) => o.id === 'day-half-am');
const addOns = pricing.addOns;
const flexi = pricing.flexiPass;
const taster = pricing.offerings.find((o) => o.id === 'day-taster');
const cbs = pricing.offerings.find((o) => o.id === 'cbs');

// Pennies shown only when present (£24.99, £12.50) — whole pounds stay clean (£15).
const gbp = (n) => `£${Number.isInteger(n) ? n.toLocaleString('en-GB') : n.toFixed(2)}`;

const pillars = [
  {
    title: 'Real socialisation',
    body: 'Planned, supervised play with regular friends of all breeds, sizes and temperaments — the foundation of a confident, well-mannered dog.',
  },
  {
    title: 'Energy, well spent',
    body: 'Walks, games and problem-solving burn off the energy that builds up at home, so the dog you collect is a happy, settled one.',
  },
  {
    title: 'Minds at work',
    body: 'Timetabled enrichment and proper learning equipment give clever dogs the mental stimulation they’re built for — far more than a day on the sofa.',
  },
  {
    title: 'Routine & structure',
    body: 'A predictable rhythm — play, lunch, rest — lowers anxiety and reinforces good habits, with gentle daily obedience woven through.',
  },
  {
    title: 'Calm & confidence',
    body: 'Our team keeps a calm, positive atmosphere; quieter dogs build confidence and resilience in a safe, controlled environment.',
  },
  {
    title: 'Time apart, made easy',
    body: 'Happy hours away from you, in good company, ease separation anxiety and teach your dog to be content on their own.',
  },
];

const daySchedule = [
  { time: '7:45 – 9:30am', title: 'Pick-up round & arrivals', body: 'Our school buses head out on their rounds and the first happy paws hit the playground.' },
  { time: '8:00 – 10:00am', title: 'Parent drop-offs', body: 'We open at 8:00am — drop your dog off any time up to 10:00am.' },
  { time: '9:30 – 10:30am', title: 'Welcome & settling in', body: 'Cuddles and calm to settle everyone in, plus health, poop and bag checks so the day starts right.' },
  { time: '10:30am – 12:00pm', title: 'Walking & enrichment', body: 'Out for walks, then into the enrichment activities that keep clever dogs happy and pleasantly tired.' },
  { time: '11:00am – 12:30pm', title: 'Lunch & feeding', body: 'A calm, supervised lunch — every dog fed their own meal, exactly as you’ve asked us to.' },
  { time: '12:30 – 1:30pm', title: 'Rest period', body: 'Downtime to recharge — indoors or out, wherever your dog is comfiest.' },
  { time: '1:30 – 2:30pm', title: 'Afternoon play & prep', body: 'More engagement and a little obedience practice, daily reports written up, and we get ready for home time.' },
  { time: 'From 3:00pm', title: 'Loading the buses', body: 'Dogs loaded into the vans, headcounts done, and the buses set off on the return run.' },
  { time: 'By 4:30pm', title: 'Home runs complete', body: 'All the school-bus return journeys are wrapped up by half past four.' },
  { time: 'Until 5:30pm', title: 'Parent pick-ups', body: 'We stay open until 5:30pm for collections — then we do it all again tomorrow!' },
];

const whyUs = [
  { icon: iconBuddies, title: 'Regular buddies', body: 'Your dog socialises with its regular friends, engaging in planned activities for the day.' },
  { icon: iconBus, title: 'Local pick-ups & drop-offs', body: 'Your dog can travel to school and back in one of our buses — saving you time and money.' },
  { icon: iconEntrance, title: 'Strict entrance criteria', body: 'A careful assessment keeps every doggy client and our staff safe and happy.' },
  { icon: iconLove, title: 'We love dogs!', body: 'Our doggy clients love our staff, and we love dogs — come and see for yourself.' },
];

const railCards = [
  { img: happyWalk, caption: 'Out on the daily walk', rotate: -2.2 },
  { img: onTheBeach, caption: 'Beach days', rotate: 1.6 },
  { img: doggyFriends, caption: 'Firm friends', rotate: -1.4 },
  { img: climbingFrame, caption: 'Enrichment equipment', rotate: 2.2 },
  { img: dogFocusing, caption: 'Learning to focus', rotate: -1.8 },
  { img: buildingConfidence, caption: 'Building confidence', rotate: 1.2 },
  { img: onTheBus, caption: 'The school bus', rotate: -2.0 },
  { img: readyForSchool, caption: 'Ready for school!', rotate: 1.8 },
];

const joinSteps = [
  { title: 'Send an enquiry', body: 'Tell us about your dog and what you’re after. We’ll be in touch to arrange your first visit.' },
  { title: 'Assessment & tasters', body: `An introductory assessment plus three taster sessions — 1 hour, then 2, then 3 — at ${gbp(taster.price)} each, so we can be sure day school suits your dog.` },
  { title: 'Welcome to the school', body: 'Once your dog is accepted, you’re all set — and ready to start booking days.' },
  { title: 'Book your days', body: 'Book full or half days to suit your week, or save with a regular weekly booking or membership.' },
];

const criteria = [
  'Every new dog has an introductory assessment plus at least three taster sessions, so we know day school is the right fit.',
  'Vaccinations up to date — DHP, Leptospirosis and Kennel Cough.',
  'Intact male dogs over six months old can’t join (unless they’re on one of our training programmes).',
  'Females in season can’t attend while they’re in season.',
  'We keep a healthy ratio of dog sizes, so your dog may go on a short waiting list until a suitable space opens up.',
  'We can’t take dogs with risky behaviour issues — they’re welcome to join our training pipeline (or work with a trainer) first.',
  'We can’t accept dogs that are allergic, on routine medication, with ongoing medical issues, or in recovery.',
  'We can’t take any dog before 8:00am.',
  'Visits are very welcome — strictly by appointment, after 4:00pm on weekdays, and without a dog.',
];

const kitList = [
  'Collar with an ID tag showing your up-to-date address and phone number',
  'An appropriate dog collar, as recommended for handling',
  'A non-retractable lead',
  'A fitted harness with a handle',
  'Vaccination card',
  'Microchip (with your address up to date)',
  'Flea-treatment self-declaration',
  'A named lunch box containing your dog’s normal meal',
  'A blanket from home',
  'Treats: plain boiled chicken only (no other treats, due to allergies)',
  'Registration form, signed and submitted before the first full day',
];
---

<Base
  title="Dog Day School & Doggy Day Care in Hastings | The Fairy Tails K9 Centre"
  description="Enrichment-led doggy day school near Hastings Country Park — structured play, socialisation, light training and daily reports. Full & half days, with local pick-up & drop-off."
  path="/dog-day-school"
>
  <div data-page="day-school">
    <!-- ============ HERO ============ -->
    <section class="relative isolate flex min-h-[92svh] items-end overflow-hidden bg-pine-950" data-hero>
      <div class="absolute inset-0 -z-10 overflow-hidden">
        <!-- Hero loop cut from the harvested "arrivals" clip; poster doubles as the
             reduced-motion/fallback state. TODO(owner): swap in fresh footage when ready. -->
        <video
          class="h-full w-full object-cover"
          poster="/media/day-school-poster.jpg"
          muted
          loop
          playsinline
          preload="none"
          data-hero-video
          data-hero-media
          aria-hidden="true"
        >
          <source src="/media/day-school-hero.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-t from-pine-950/95 via-pine-950/45 to-pine-950/25"></div>
      </div>

      <div class="mx-auto w-full max-w-6xl px-4 pb-24 pt-36 sm:pb-28">
        <p class="eyebrow text-honey-300" data-hero-eyebrow>Doggy Day School · Hastings Country Park</p>
        <h1 class="mt-4 max-w-3xl font-display text-[2.6rem] font-bold leading-[1.05] text-cream-50 sm:text-6xl" data-hero-title>
          <span class="hero-line block">Where dogs learn that</span>
          <span class="hero-line block"><em class="squiggle not-italic">learning is fun</em></span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-cream-100/90" data-hero-sub>
          A fun, safe place for your dog to stay, play and learn — busy days of friends, enrichment
          and structure, with you back to calm, happy evenings.
        </p>
        <div class="mt-9 flex flex-wrap gap-4" data-hero-cta>
          <a href="#enquire" class="btn btn-honey">
            Send an enquiry <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <a href={business.acuity.main} class="btn btn-ghost-light"> Already with us? Book your days </a>
        </div>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-cream-100/70" data-hero-cue aria-hidden="true">
        <svg width="22" height="30" viewBox="0 0 22 30" fill="none" class="animate-bounce">
          <rect x="1" y="1" width="20" height="28" rx="10" stroke="currentColor" stroke-width="2"></rect>
          <circle cx="11" cy="10" r="3" fill="currentColor"></circle>
        </svg>
      </div>
    </section>

    <!-- Trust strip — overlaps the hero -->
    <div class="relative z-10 mx-auto -mt-12 max-w-5xl px-4" data-hero-trust>
      <ul class="grain grid gap-4 rounded-2xl bg-cream-50 px-7 py-6 text-sm font-bold text-bark-700 shadow-[var(--shadow-polaroid)] sm:grid-cols-3 sm:gap-2">
        <li class="paw-bullet flex items-center text-moss-700">Enrichment-led, not just minded</li>
        <li class="paw-bullet flex items-center text-moss-700">Local pick-up &amp; drop-off</li>
        <li class="paw-bullet flex items-center text-moss-700">Daily reports, straight to you</li>
      </ul>
    </div>

    <!-- ============ WELCOME ============ -->
    <section class="mx-auto max-w-6xl px-4 py-20 sm:py-28" data-section="welcome">
      <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <p class="eyebrow text-honey-600" data-reveal>Welcome to day school</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
            A proper day out — for <em class="squiggle not-italic">dogs</em>
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-bark-700" data-reveal>
            The day school programme at The Fairy Tails offers a fun and safe place for your dog to
            stay, play and learn. It’s a great way for them to stay happy, active and busy — and to
            socialise with fellow furry friends.
          </p>
          <p class="mt-4 leading-relaxed text-bark-700" data-reveal>
            For training and enrichment we have plenty of space, learning equipment and timetabled
            activities. Our schooling programme is designed to engage dogs safely and effectively,
            with positive behaviour in mind.
          </p>
        </div>
        <figure class="polaroid mx-auto w-full max-w-sm" style="transform: rotate(-2deg);" data-reveal>
          <Image
            src={doggyFriends}
            alt="Day-school dogs playing together at The Fairy Tails"
            class="aspect-[4/5] w-full rounded-[2px] object-cover"
            widths={[480, 960]}
            sizes="(min-width: 1024px) 24rem, 90vw"
          />
          <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">
            Fellow furry friends
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- ============ WHY DAY SCHOOL — ENRICHMENT ============ -->
    <section class="bg-cream-100" data-section="enrichment">
      <HillDivider class="bg-cream-50 text-cream-100" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div>
            <p class="eyebrow text-honey-600" data-reveal>Why day school</p>
            <h2 class="mt-3 max-w-xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
              Dogs were built for a <em class="squiggle not-italic">busier world</em>
            </h2>
            <p class="mt-5 text-lg leading-relaxed text-bark-700" data-reveal>
              A feral dog can spend as much as 70% of its day hunting and searching for food — real
              physical effort and real problem-solving. For many of our companions, the day is eight
              hours or more just waiting for us to come home.
            </p>
            <p class="mt-4 leading-relaxed text-bark-700" data-reveal>
              Years of domestication made dogs wonderful company, but they still need enrichment in
              their lives. That’s where we come in — a day full of the movement, stimulation and
              friendship they’re wired for.
            </p>
          </div>
          <!-- overlapping photo cluster -->
          <div class="relative mx-auto h-[24rem] w-full max-w-md" data-reveal>
            <figure class="polaroid absolute left-0 top-2 w-3/5" style="transform: rotate(-4deg);">
              <Image src={enrichmentWoods} alt="Enrichment walk in the woods" class="aspect-[4/5] w-full rounded-[2px] object-cover" widths={[360, 720]} sizes="16rem" />
            </figure>
            <figure class="polaroid absolute bottom-0 right-0 w-3/5" style="transform: rotate(3.5deg);">
              <Image src={climbingFrame} alt="A dog exploring the climbing frame" class="aspect-square w-full rounded-[2px] object-cover" widths={[360, 720]} sizes="16rem" />
            </figure>
          </div>
        </div>

        <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
          {
            pillars.map((p) => (
              <article class="grain rounded-2xl bg-cream-50 p-7 shadow-[var(--shadow-lift)] transition-transform duration-300 hover:-translate-y-1.5">
                <h3 class="font-display text-xl font-bold text-moss-700">{p.title}</h3>
                <p class="mt-3 leading-relaxed text-bark-700">{p.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ A DAY IN THE LIFE — signature scroll story ============ -->
    <section class="relative overflow-hidden bg-pine-950 text-cream-100" data-section="day">
      <HillDivider class="relative z-10 bg-cream-100 text-pine-950" flip />
      <div class="pointer-events-none absolute inset-x-0 top-0 z-0 h-2/3" aria-hidden="true" style="background: radial-gradient(70% 55% at 50% 0%, rgba(236,194,124,0.16), transparent 72%);"></div>
      <div class="relative z-10 mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-400" data-reveal>A day in the life</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-cream-50 sm:text-4xl" data-reveal>
          From morning bus to <em class="squiggle not-italic">happy tired</em>
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-cream-200" data-reveal>
          Most days follow this rhythm. Times flow into one another — some dogs arrive on the bus
          while others are dropped off — but here’s how a typical day unfolds.
        </p>

        <!-- The walk: a trail fills + a paw walks down it as you scroll -->
        <div class="relative mt-14 overflow-x-clip" data-day-list>
          <div class="absolute bottom-4 left-[7px] top-2 w-0.5 sm:left-[166px]" aria-hidden="true">
            <div class="absolute inset-0 rounded bg-pine-800"></div>
            <div class="day-trail absolute inset-0 origin-top rounded" data-trail-fill></div>
            <span class="day-sun absolute -left-[15px] top-0 block h-8 w-8" data-trail-sun>
              <svg viewBox="0 0 32 32" fill="none" class="h-full w-full">
                <circle cx="16" cy="16" r="6" fill="var(--color-honey-300)"></circle>
                <g stroke="var(--color-honey-300)" stroke-width="2" stroke-linecap="round">
                  <line x1="16" y1="2" x2="16" y2="5.5"></line>
                  <line x1="16" y1="26.5" x2="16" y2="30"></line>
                  <line x1="2" y1="16" x2="5.5" y2="16"></line>
                  <line x1="26.5" y1="16" x2="30" y2="16"></line>
                  <line x1="6.3" y1="6.3" x2="8.8" y2="8.8"></line>
                  <line x1="23.2" y1="23.2" x2="25.7" y2="25.7"></line>
                  <line x1="6.3" y1="25.7" x2="8.8" y2="23.2"></line>
                  <line x1="23.2" y1="8.8" x2="25.7" y2="6.3"></line>
                </g>
              </svg>
            </span>
          </div>

          <ol class="space-y-10 sm:space-y-12">
            {
              daySchedule.map((step) => (
                <li class="day-step relative grid gap-2 pl-9 sm:grid-cols-[140px_1fr] sm:gap-12 sm:pl-0" data-day-step>
                  <p class="font-display text-base font-bold uppercase tracking-wide text-honey-400 sm:text-right">
                    {step.time}
                  </p>
                  <div class="sm:pl-14">
                    <h3 class="font-display text-2xl font-bold text-cream-50">{step.title}</h3>
                    <p class="mt-2 max-w-2xl leading-relaxed text-cream-200">{step.body}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>

        <p class="mt-14 max-w-3xl rounded-2xl bg-pine-900 p-6 leading-relaxed text-cream-100" data-reveal>
          <strong class="text-honey-300">Our hours:</strong> we’re open Monday to Friday, 8:00am to
          5:30pm (closed weekends and bank holidays). School-bus pick-up and drop-off times vary with
          your location — we’ll set yours when your dog joins.
        </p>
      </div>
    </section>

    <!-- ============ WHY PEOPLE CHOOSE US ============ -->
    <section data-section="choose">
      <HillDivider class="bg-pine-950 text-cream-50" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-600" data-reveal>Why people choose us</p>
        <h2 class="mt-3 font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
          The little things that <em class="squiggle not-italic">add up</em>
        </h2>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
          {
            whyUs.map((item) => (
              <article class="why-card grain rounded-2xl bg-cream-50 p-7 text-center shadow-[var(--shadow-lift)] transition-transform duration-300 hover:-translate-y-1.5">
                <span class="why-icon mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-moss-100">
                  <img src={item.icon.src} alt="" width="36" height="36" class="h-9 w-9" loading="lazy" />
                </span>
                <h3 class="mt-5 font-display text-lg font-bold text-moss-800">{item.title}</h3>
                <p class="mt-2.5 text-sm leading-relaxed text-bark-700">{item.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ============ PROOF ============ -->
    <section class="overflow-hidden bg-cream-100" data-section="proof">
      <HillDivider class="bg-cream-50 text-cream-100" />
      <div class="mx-auto max-w-6xl px-4 pb-20 pt-12 sm:pb-28">
        <p class="eyebrow text-honey-600" data-reveal>Proof, not promises</p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-bold text-moss-800 sm:text-4xl" data-reveal>
          Don’t just take our <em class="squiggle not-italic">word for it</em>
        </h2>

        <div class="mt-12 grid items-start gap-8 lg:grid-cols-2" data-stagger>
          <!-- promo clip (click to play) -->
          <figure class="grain rounded-2xl bg-cream-50 p-3 shadow-[var(--shadow-lift)]">
            <video
              class="aspect-video w-full rounded-xl bg-pine-950 object-cover"
              controls
              preload="none"
              playsinline
              poster="/media/day-school-promo-poster.jpg"
            >
              <source src="/media/day-school-promo.mp4" type="video/mp4" />
            </video>
            <figcaption class="px-1 pt-3 font-display text-sm font-bold text-bark-700">
              A day with us — straight off the cameras
            </figcaption>
          </figure>

          <!-- daily reports -->
          <div>
            <h3 class="font-display text-2xl font-bold text-moss-800">Real reports, every day</h3>
            <p class="mt-3 leading-relaxed text-bark-700">
              You don’t just collect a tired dog — you get to see their day. Every dog goes home with
              a daily report, and Confidence Building sessions are recorded on camera with a video
              link sent straight to you.
            </p>
            <div class="mt-6 flex flex-wrap gap-5">
              <figure class="polaroid w-40 sm:w-48" style="transform: rotate(-2.5deg);">
                <Image src={dayReport} alt="Example Day School daily report" class="w-full rounded-[2px]" widths={[200, 400]} sizes="12rem" />
                <figcaption class="px-1 pt-2 text-center font-display text-xs font-bold text-bark-700">Daily report</figcaption>
              </figure>
              <figure class="polaroid w-40 sm:w-48" style="transform: rotate(2.5deg);">
                <Image src={cbsReport} alt="Example Confidence Building Session report" class="w-full rounded-[2px]" widths={[200, 400]} sizes="12rem" />
                <figcaption class="px-1 pt-2 text-center font-display text-xs font-bold text-bark-700">CBS video report</figcaption>
              </figure>
            </div>
          </div>
        </div>
      </div>

      <!-- Draggable polaroid rail (full-bleed) -->
      <div class="pb-4" data-reveal>
        <h3 class="mx-auto max-w-6xl px-4 font-display text-2xl font-bold text-moss-800">
          A few of our day-school regulars
        </h3>
        <p class="mx-auto mt-1 max-w-6xl px-4 text-sm font-bold text-bark-400">
          Drag to explore <span aria-hidden="true">⟷</span>
        </p>
        <div
          class="drag-track mt-6 flex snap-x snap-mandatory gap-7 overflow-x-auto px-[max(1rem,calc((100vw-72rem)/2+1rem))] pb-6 pt-2"
          data-drag-track
        >
          {
            railCards.map(({ img, caption, rotate }) => (
              <figure class="polaroid w-64 shrink-0 snap-start sm:w-72" style={`transform: rotate(${rotate}deg);`}>
                <Image
                  src={img}
                  alt={caption}
                  class="aspect-square w-full rounded-[2px] object-cover"
                  widths={[480, 960]}
                  sizes="18rem"
                  draggable={false}
                />
                <figcaption class="px-1 pt-3 text-center font-display text-sm font-bold text-bark-700">{caption}</figcaption>
              </figure>
            ))
          }
        </div>
      </div>

