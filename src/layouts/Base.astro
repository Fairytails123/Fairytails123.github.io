---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/karla';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { business } from '../data/business';
import { buildSiteGraph, ORG_ID, WEBSITE_ID } from '../data/schema';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';

interface Props {
  title: string;
  description: string;
  /** Path beginning with /, e.g. /dog-boarding-school */
  path: string;
  ogImage?: string | undefined;
  /** og:type for this template. 'article' for blog posts; 'website' otherwise. */
  ogType?: string | undefined;
  /**
   * ISO date (YYYY-MM-DD) of the last GENUINE content review of this page.
   *
   * Renders a visible "last reviewed and updated <Month Year>" line and emits a
   * WebPage node carrying dateModified. Freshness is a real ranking and
   * AI-citation signal (the <3-months cohort is cited ~3x more often), but the
   * date is only worth having if it is TRUE: bump it when the page's content
   * genuinely changes, never on a routine rebuild, and never automatically from
   * the build clock — a date that drifts ahead of the content is a lie we would
   * be telling on every page at once.
   */
  updated?: string | undefined;
}

const { title, description, path, ogImage, ogType = 'website', updated } = Astro.props;
const canonical = `${business.domain}${path === '/' ? '' : path}`;
const updatedDisplay = updated
  ? new Intl.DateTimeFormat('en-GB', { month: 'long', year: 'numeric', timeZone: 'UTC' }).format(
      new Date(`${updated}T00:00:00Z`)
    )
  : null;
// A WebPage node ONLY when the page states a real review date — it exists to
// carry dateModified. It references the one business entity and the one
// WebSite by @id rather than restating either (see data/schema.ts).
const webPageLd = updated
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      '@id': `${canonical}#webpage`,
      url: canonical,
      name: title,
      description,
      dateModified: updated,
      isPartOf: { '@id': WEBSITE_ID },
      about: { '@id': ORG_ID },
      inLanguage: 'en-GB',
    }
  : null;
const gtmId = business.tracking.gtm;
// The ONE business entity, emitted once per page. Every other JSON-LD node on
// the site references it by @id rather than restating it — see data/schema.ts.
const siteGraph = buildSiteGraph();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <script type="application/ld+json" set:html={JSON.stringify(siteGraph)} is:inline />
    {webPageLd && <script type="application/ld+json" set:html={JSON.stringify(webPageLd)} is:inline />}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {/* Pages with a hero pass their own ogImage; everything else gets the site
        default (a stable public/ file — /og-default.jpg — so the URL never
        changes with build hashes; owner-chosen photo, 2026-07-16). */}
    <meta property="og:image" content={ogImage ?? `${business.domain}/og-default.jpg`} />
    {!ogImage && <meta property="og:image:width" content="1200" />}
    {!ogImage && <meta property="og:image:height" content="630" />}
    <meta property="og:site_name" content={business.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Brand favicon set (owner, 2026-07-12: the logo, not a placeholder — Google
         needs a ≥48px multiple to show it beside the URL in search results). -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />

    <!-- Consent Mode v2: defaults DENIED before GTM loads (UK PECR) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });
      try {
        var saved = localStorage.getItem('ft-consent');
        if (saved) gtag('consent', 'update', JSON.parse(saved));
      } catch (e) {}
    </script>
    <script is:inline define:vars={{ gtmId }}>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', gtmId);
    </script>
  </head>
  <body>
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>
    <Header />
    <main>
      <slot />
      {
        updatedDisplay && (
          <p class="mx-auto max-w-6xl px-4 pt-12 text-center text-sm text-bark-500">
            This page was last reviewed and updated <time datetime={updated}>{updatedDisplay}</time>.
          </p>
        )
      }
    </main>
    <Footer />
    <ConsentBanner />

    <script>
      // GA4 measurement. Reports what GTM cannot see by itself — above all the page_view
      // for Astro view transitions, which a stock GA4 install silently misses.
      // Read the header comment in src/scripts/analytics.ts before touching this.
      import { initAnalytics } from '../scripts/analytics';
      initAnalytics();
    </script>
  </body>
</html>
