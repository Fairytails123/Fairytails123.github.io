---
import { Image } from 'astro:assets';
import { business } from '../data/business';
import logo from '../assets/brand/logo.png';

// Inside-out build: nav links are added as pages go live on the preview
// (WEBSITE-PLAN.md risk #8). Currently live: Board & Train, Intensive Dog Training,
// Dog Day School, Gallery, Blog.
const nav = [
  { label: 'Board & Train', href: '/dog-boarding-school' },
  { label: 'Intensive Dog Training', href: '/intensive-dog-training' },
  { label: 'Dog Day School', href: '/dog-day-school' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Blog', href: '/blog' },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-40 transition-[background-color,box-shadow,padding] duration-300"
  data-header
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-2">
      <Image
        src={logo}
        alt="The Fairy Tails K9 Centre"
        class="h-11 w-auto transition-transform duration-300 sm:h-13"
        densities={[1, 2]}
        height={52}
        data-header-logo
      />
      <span class="sr-only">The Fairy Tails K9 Centre — home</span>
    </a>

    <nav aria-label="Main" class="hidden items-center gap-5 md:flex lg:gap-7">
      {
        nav.map((item) => (
          <a href={item.href} class="nav-link text-sm font-bold text-bark-700">
            {item.label}
          </a>
        ))
      }
      <a href={business.phones.main.tel} class="nav-link hidden text-sm font-bold text-bark-700 lg:block">
        {business.phones.main.display}
      </a>
      <a href="/#enquire" class="btn btn-moss !px-5 !py-2.5 text-sm"> Enquire </a>
      <a href={business.acuity.bookAppointment} class="btn btn-honey !px-5 !py-2.5 text-sm">
        Book Appointment
      </a>
    </nav>

    <button
      type="button"
      class="relative z-50 flex h-11 w-11 items-center justify-center rounded-full bg-cream-50/80 md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-toggle
    >
      <span class="menu-bars relative block h-3.5 w-5">
        <span class="menu-bar absolute left-0 top-0 h-0.5 w-full rounded bg-bark-900"></span>
        <span class="menu-bar absolute left-0 top-1/2 h-0.5 w-full -translate-y-1/2 rounded bg-bark-900"></span>
        <span class="menu-bar absolute bottom-0 left-0 h-0.5 w-full rounded bg-bark-900"></span>
      </span>
    </button>
  </div>

  <!-- Mobile slide-in panel -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 hidden md:hidden"
    data-menu-panel
    aria-hidden="true"
  >
    <div class="absolute inset-0 bg-pine-950/60 opacity-0" data-menu-backdrop></div>
    <div
      class="absolute right-0 top-0 flex h-full w-[82%] max-w-sm translate-x-full flex-col justify-between bg-cream-50 p-8 pt-24 shadow-2xl"
      data-menu-drawer
    >
      <nav aria-label="Mobile" class="space-y-2">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="block py-3 font-display text-2xl font-bold text-moss-800"
              data-menu-link
            >
              {item.label}
            </a>
          ))
        }
        <a
          href={business.acuity.bookAppointment}
          class="btn btn-honey mt-6 w-full"
          data-menu-link
        >
          Book Appointment
        </a>
        <a
          href="/#enquire"
          class="btn btn-moss mt-3 w-full"
          data-menu-link
        >
          Enquire
        </a>
      </nav>
      <div class="space-y-2 text-sm text-bark-700">
        <a href={business.phones.main.tel} class="block font-bold" data-menu-link>
          Call {business.phones.main.display}
        </a>
        <a href={business.phones.main.whatsapp} class="block font-bold" data-menu-link>
          WhatsApp us
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link {
    position: relative;
    padding-bottom: 2px;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    height: 2px;
    width: 100%;
    border-radius: 2px;
    background: var(--color-honey-500);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  /* The scrolled backdrop lives on a ::before, NOT on the header itself:
     backdrop-filter on [data-header] would make it the containing block for
     the position:fixed mobile panel, clipping the drawer to the header bar. */
  [data-header]::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(in srgb, var(--color-cream-50) 92%, transparent);
    backdrop-filter: blur(10px);
    box-shadow: 0 1px 0 rgb(43 37 30 / 0.06), 0 8px 24px -16px rgb(43 37 30 / 0.25);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  [data-header].is-scrolled::before {
    opacity: 1;
  }
  [data-header].is-scrolled [data-header-logo] {
    transform: scale(0.88);
  }
  /* Hamburger -> X */
  [data-menu-toggle][aria-expanded='true'] .menu-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  [data-menu-toggle][aria-expanded='true'] .menu-bar:nth-child(2) {
    opacity: 0;
  }
  [data-menu-toggle][aria-expanded='true'] .menu-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
  .menu-bar {
    transition: transform 0.3s ease, opacity 0.2s ease;
  }
  [data-menu-backdrop] {
    transition: opacity 0.35s ease;
  }
  [data-menu-drawer] {
    /* Tailwind v4's translate-x-full sets the `translate` property, not `transform` */
    transition: translate 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-menu-panel].is-open [data-menu-backdrop] {
    opacity: 1;
  }
  [data-menu-panel].is-open [data-menu-drawer] {
    translate: 0 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-link::after,
    .menu-bar,
    [data-menu-backdrop],
    [data-menu-drawer],
    [data-header]::before,
    [data-header-logo] {
      transition: none;
    }
  }
</style>

<script>
  function initHeader() {
    const header = document.querySelector('[data-header]');
    if (!header || (header as HTMLElement).dataset.init) return;
    (header as HTMLElement).dataset.init = '1';

    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 24);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    const toggle = header.querySelector('[data-menu-toggle]') as HTMLButtonElement;
    const panel = header.querySelector('[data-menu-panel]') as HTMLElement;
    const backdrop = header.querySelector('[data-menu-backdrop]') as HTMLElement;
    if (!toggle || !panel) return;

    let open = false;
    const setOpen = (next: boolean) => {
      open = next;
      toggle.setAttribute('aria-expanded', String(next));
      toggle.setAttribute('aria-label', next ? 'Close menu' : 'Open menu');
      panel.setAttribute('aria-hidden', String(!next));
      document.documentElement.style.overflow = next ? 'hidden' : '';
      if (next) {
        panel.classList.remove('hidden');
        requestAnimationFrame(() => panel.classList.add('is-open'));
      } else {
        panel.classList.remove('is-open');
        setTimeout(() => !open && panel.classList.add('hidden'), 450);
      }
    };

    toggle.addEventListener('click', () => setOpen(!open));
    backdrop?.addEventListener('click', () => setOpen(false));
    panel.querySelectorAll('[data-menu-link]').forEach((a) => {
      a.addEventListener('click', () => setOpen(false));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) setOpen(false);
    });
    document.addEventListener('astro:before-swap', () => setOpen(false));
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
