---
import { business } from '../data/business';
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-cream-200 bg-moss-900 text-cream-100">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:grid-cols-3">
    <div>
      <p class="font-display text-lg font-bold text-cream-50">The Fairy Tails K9 Centre</p>
      <address class="mt-2 text-sm not-italic leading-relaxed text-cream-200">
        {business.address.line1}<br />
        {business.address.line2}<br />
        {business.address.town} {business.address.postcode}
      </address>
      <a href={business.mapsUrl} class="mt-2 inline-block text-sm underline hover:text-honey-300">
        Find us on Google Maps
      </a>
      <p class="mt-3 text-sm text-cream-200">{business.hours.display}</p>
    </div>
    <div>
      <p class="font-semibold text-cream-50">Talk to us</p>
      <ul class="mt-2 space-y-1 text-sm">
        <li>
          <a href={business.phones.main.tel} class="hover:text-honey-300">
            {business.phones.main.label}: {business.phones.main.display}
          </a>
        </li>
        <li>
          <a href={business.phones.textLine.whatsapp} class="hover:text-honey-300">
            WhatsApp: {business.phones.textLine.display}
          </a>
        </li>
        <li>
          <a href={`mailto:${business.emails.info}`} class="hover:text-honey-300">
            {business.emails.info}
          </a>
        </li>
      </ul>
      <ul class="mt-3 flex gap-4 text-sm">
        <li><a href={business.socials.facebook} class="underline hover:text-honey-300">Facebook</a></li>
        <li><a href={business.socials.instagram} class="underline hover:text-honey-300">Instagram</a></li>
      </ul>
    </div>
    <div>
      <p class="font-semibold text-cream-50">Explore</p>
      <ul class="mt-2 space-y-1 text-sm">
        <li><a href="/dog-boarding-school" class="hover:text-honey-300">Board & Train</a></li>
        <li><a href={business.groomingSite} class="hover:text-honey-300">Dog Grooming (sister site)</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-moss-800 py-4 text-center text-xs text-cream-200">
    © {year} The Fairy Tails K9 Centre
  </div>
</footer>
